%description:
Test serialization and deserialization of Ieee80211HeMuPhyHeader.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeSigCodec.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/common/packet/Packet.h"
#include "inet/common/packet/serializer/ChunkSerializerRegistry.h"

%global:

using namespace inet;
using namespace inet::physicallayer;

%activity:

// Create original HeMuPhyHeader
auto origHeader = makeShared<Ieee80211HeMuPhyHeader>();
auto headerRus = getHeEqualRuLayout(Hz(0), Hz(20e6), 2);

Ieee80211HeMuUserInfo user1;
user1.ruIndex = headerRus[0].index;
user1.ruToneSize = headerRus[0].toneSize;
user1.ruToneOffset = headerRus[0].toneOffset;
user1.staId = 0x155;
user1.mcs = 4;
user1.numberOfSpatialStreams = 1;
origHeader->appendUsers(user1);

Ieee80211HeMuUserInfo user2;
user2.ruIndex = headerRus[1].index;
user2.ruToneSize = headerRus[1].toneSize;
user2.ruToneOffset = headerRus[1].toneOffset;
user2.staId = 0x2aa;
user2.mcs = 5;
user2.numberOfSpatialStreams = 2;
origHeader->appendUsers(user2);

origHeader->setChunkLength(b(120));

EV << "Original Header:\n";
EV << "users count = " << origHeader->getUsersArraySize() << "\n";
for (unsigned int i = 0; i < origHeader->getUsersArraySize(); ++i) {
    EV << "  user[" << i << "]: staId=" << origHeader->getUsers(i).staId
       << ", mcs=" << (int)origHeader->getUsers(i).mcs
       << ", nss=" << (int)origHeader->getUsers(i).numberOfSpatialStreams << "\n";
}

// Put in a packet
auto pk = new Packet("test-packet");
pk->insertAtFront(origHeader);

// Serialize packet to raw bytes
auto bytes = pk->peekDataAsBytes();
EV << "Serialized to " << bytes->getChunkLength().get<B>() << " bytes\n";

// Put bytes back in a new packet
auto pk2 = new Packet("recv-packet");
pk2->insertAtFront(bytes);

// Deserialize header
auto recvHeader = pk2->popAtFront<Ieee80211HeMuPhyHeader>();

EV << "Deserialized Header:\n";
EV << "users count = " << recvHeader->getUsersArraySize() << "\n";
for (unsigned int i = 0; i < recvHeader->getUsersArraySize(); ++i) {
    EV << "  user[" << i << "]: staId=" << recvHeader->getUsers(i).staId
       << ", mcs=" << (int)recvHeader->getUsers(i).mcs
       << ", nss=" << (int)recvHeader->getUsers(i).numberOfSpatialStreams << "\n";
}
ASSERT(recvHeader->getUsers(0).ruToneSize == headerRus[0].toneSize);
ASSERT(recvHeader->getUsers(1).ruToneSize == headerRus[1].toneSize);

auto rus = getHeEqualRuLayout(Hz(5.18e9), Hz(80e6), 4);
auto encoded = encodeHeSigBRuAllocation(rus, Hz(80e6));
ASSERT(encoded);
auto decoded = decodeHeSigBRuAllocation(encoded.allocation.allocationCodes,
        Hz(5.18e9), Hz(80e6));
ASSERT(decoded);
ASSERT(decoded.allocation.rus.size() == rus.size());
for (size_t i = 0; i < rus.size(); ++i) {
    ASSERT(decoded.allocation.rus[i].toneSize == rus[i].toneSize);
    ASSERT(decoded.allocation.rus[i].toneOffset == rus[i].toneOffset);
}
auto overlapping = rus;
overlapping.push_back(rus.front());
ASSERT(!encodeHeSigBRuAllocation(overlapping, Hz(80e6)));
EV << "HE-SIG-B RU layout codec round-trip and overlap validation passed.\n";

auto delimiter = makeShared<ieee80211::Ieee80211MpduSubframeHeader>();
delimiter->setEof(true);
delimiter->setLength(1234);
auto delimiterPacket = new Packet("delimiter");
delimiterPacket->insertAtFront(delimiter);
auto delimiterBytes = delimiterPacket->peekDataAsBytes();
auto parsedDelimiterPacket = new Packet("parsed-delimiter");
parsedDelimiterPacket->insertAtFront(delimiterBytes);
auto parsedDelimiter = parsedDelimiterPacket->popAtFront<ieee80211::Ieee80211MpduSubframeHeader>();
ASSERT(parsedDelimiter->getEof());
ASSERT(parsedDelimiter->getReserved() == 0);
ASSERT(parsedDelimiter->getLength() == 1234);
ASSERT(parsedDelimiter->getSignature() == 0x4E);
ASSERT(!parsedDelimiter->isIncorrect());
delete delimiterPacket;
delete parsedDelimiterPacket;
EV << "A-MPDU delimiter EOF, length, CRC, and signature round-trip passed.\n";

delete pk;
delete pk2;
EV << ".\n";

%contains: stdout
Original Header:
users count = 2
  user[0]: staId=341, mcs=4, nss=1
  user[1]: staId=682, mcs=5, nss=2
Serialized to 15 bytes
Deserialized Header:
users count = 2
  user[0]: staId=341, mcs=4, nss=1
  user[1]: staId=682, mcs=5, nss=2
HE-SIG-B RU layout codec round-trip and overlap validation passed.
A-MPDU delimiter EOF, length, CRC, and signature round-trip passed.
.
