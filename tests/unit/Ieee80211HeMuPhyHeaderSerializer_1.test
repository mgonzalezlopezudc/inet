%description:
Test serialization and deserialization of Ieee80211HeMuPhyHeader.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/common/packet/Packet.h"
#include "inet/common/packet/serializer/ChunkSerializerRegistry.h"

%global:

using namespace inet;
using namespace inet::physicallayer;

%activity:

// Create original HeMuPhyHeader
auto origHeader = makeShared<Ieee80211HeMuPhyHeader>();

Ieee80211HeMuUserInfo user1;
user1.ruIndex = 2;
user1.staId = 0x155;
user1.mcs = 4;
user1.numberOfSpatialStreams = 1;
origHeader->appendUsers(user1);

Ieee80211HeMuUserInfo user2;
user2.ruIndex = 4;
user2.staId = 0x2aa;
user2.mcs = 5;
user2.numberOfSpatialStreams = 2;
origHeader->appendUsers(user2);

origHeader->setChunkLength(b(16 + origHeader->getUsersArraySize() * 73));

EV << "Original Header:\n";
EV << "users count = " << origHeader->getUsersArraySize() << "\n";
for (unsigned int i = 0; i < origHeader->getUsersArraySize(); ++i) {
    EV << "  user[" << i << "]: ruIndex=" << origHeader->getUsers(i).ruIndex
       << ", staId=" << origHeader->getUsers(i).staId
       << ", mcs=" << (int)origHeader->getUsers(i).mcs
       << ", nss=" << (int)origHeader->getUsers(i).numberOfSpatialStreams << "\n";
}

// Put in a packet
auto pk = new Packet("test-packet");
pk->insertAtFront(origHeader);

// Serialize packet to raw bytes
auto bytes = pk->peekDataAsBytes();
EV << "Serialized to " << bytes->getChunkLength().get<B>() << " bytes\n";

// Put bytes back in a new packet
auto pk2 = new Packet("recv-packet");
pk2->insertAtFront(bytes);

// Deserialize header
auto recvHeader = pk2->popAtFront<Ieee80211HeMuPhyHeader>();

EV << "Deserialized Header:\n";
EV << "users count = " << recvHeader->getUsersArraySize() << "\n";
for (unsigned int i = 0; i < recvHeader->getUsersArraySize(); ++i) {
    EV << "  user[" << i << "]: ruIndex=" << recvHeader->getUsers(i).ruIndex
       << ", staId=" << recvHeader->getUsers(i).staId
       << ", mcs=" << (int)recvHeader->getUsers(i).mcs
       << ", nss=" << (int)recvHeader->getUsers(i).numberOfSpatialStreams << "\n";
}

delete pk;
delete pk2;
EV << ".\n";

%contains: stdout
Original Header:
users count = 2
  user[0]: ruIndex=2, staId=341, mcs=4, nss=1
  user[1]: ruIndex=4, staId=682, mcs=5, nss=2
Serialized to 21 bytes
Deserialized Header:
users count = 2
  user[0]: ruIndex=2, staId=341, mcs=4, nss=1
  user[1]: ruIndex=4, staId=682, mcs=5, nss=2
.
