%description:
Test HE MU RU attenuation behavior — verifies that each RU sub-channel is attenuated
based on its own center frequency and bandwidth, not the aggregate channel.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211RadioMedium.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Transmission.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeMuTag.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211ModeSet.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/ITransmitterAnalogModel.h"
#include "inet/networklayer/common/NetworkInterface.h"
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/Protocol.h"
#include "inet/common/packet/Packet.h"

%file: TestNetwork.ned

import inet.networklayer.common.InterfaceTable;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211RadioMedium;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211Receiver;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211ScalarRadio;
import inet.mobility.static.StationaryMobility;

module DummyReceiverModule extends Ieee80211Receiver
{
    parameters:
        @class(DummyReceiverModule);
}

module MockNic
{
    parameters:
        @class(MockNicModule);
    submodules:
        radio: Ieee80211ScalarRadio {
            receiver.typename = "DummyReceiverModule";
        }
    connections allowunconnected:
        radio.upperLayerOut --> radio.upperLayerIn;
}

network TestNetwork
{
    parameters:
        @networkNode;
    submodules:
        test: Test;
        interfaceTable: InterfaceTable;
        radioMedium: Ieee80211RadioMedium;
        mobility: StationaryMobility;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork
**.receiver.typename = "DummyReceiverModule"
**.nic*.interfaceTableModule = "^.interfaceTable"
**.mobilityModule = "^.^.^.mobility"
**.mobility.subjectModule = ""
**.constraintAreaMinX = 0m
**.constraintAreaMinY = 0m
**.constraintAreaMinZ = 0m
**.constraintAreaMaxX = 100m
**.constraintAreaMaxY = 100m
**.constraintAreaMaxZ = 0m
**.receiver.energyDetection = -100dBm
**.receiver.sensitivity = -90dBm
**.receiver.centerFrequency = 5.18GHz
**.receiver.bandwidth = 20MHz
**.receiver.modulation = "BPSK"
**.receiver.snirThreshold = 4dB
**.receiver.opMode = "ax"
**.receiver.bandName = "5 GHz"
**.receiver.channelNumber = 36

%global:

using namespace inet;
using namespace inet::physicallayer;

class MockIeee80211Transmission : public Ieee80211Transmission
{
  public:
    MockIeee80211Transmission(const IRadio *transmitter, const Packet *packet, const IIeee80211Mode *mode, const Ieee80211Channel *channel)
        : Ieee80211Transmission(
            transmitter,
            packet,
            0.0, 0.0, // startTime, endTime
            0.0, 0.0, 0.0, // preamble, header, data duration
            Coord(), Coord(), // start, end position
            Quaternion(), Quaternion(), // start, end orientation
            nullptr, nullptr, nullptr, nullptr, nullptr, // models
            mode, channel
        ) {}
};

class DummyReceiverModule : public Ieee80211Receiver {
  public:
    // Expose protected methods for testing
    bool checkAssigned(const ITransmission *transmission) const {
        return isAssignedHeMuRu(transmission);
    }
};

class MockNicModule : public NetworkInterface {
  protected:
    virtual void initialize(int stage) override {
        if (stage == INITSTAGE_LOCAL) {
            state = UP;
            carrier = true;
        }
    }
    virtual int numInitStages() const override { return 1; }
};

Define_Module(DummyReceiverModule);
Define_Module(MockNicModule);

%activity:

// Get dynamic module type for MockNic
cModuleType *nicType = cModuleType::find("MockNic");
if (!nicType) {
    throw cRuntimeError("Could not find MockNic module type");
}

// Instantiate two NIC modules to act as two stations receiving different RUs
cModule *nic1 = nicType->create("nic1", getSystemModule());
nic1->buildInside();
auto netIface1 = check_and_cast<MockNicModule *>(nic1);
netIface1->setMacAddress(MacAddress("00:11:22:33:44:55"));
nic1->callInitialize();

cModule *nic2 = nicType->create("nic2", getSystemModule());
nic2->buildInside();
auto netIface2 = check_and_cast<MockNicModule *>(nic2);
netIface2->setMacAddress(MacAddress("66:77:88:99:AA:BB"));
nic2->callInitialize();

// Get receiver modules
auto rxModule1 = check_and_cast<DummyReceiverModule *>(nic1->getSubmodule("radio")->getSubmodule("receiver"));
auto rxModule2 = check_and_cast<DummyReceiverModule *>(nic2->getSubmodule("radio")->getSubmodule("receiver"));

auto radio1 = check_and_cast<IRadio *>(nic1->getSubmodule("radio"));
auto radio2 = check_and_cast<IRadio *>(nic2->getSubmodule("radio"));

// Get mode and channel for transmissions
auto modeSet = Ieee80211ModeSet::getModeSet("ax");
auto mode = const_cast<Ieee80211ModeSet *>(modeSet)->getMode(0);
auto channel = new Ieee80211Channel(nullptr, 1);

// Create channel with 20 MHz bandwidth for 2 RUs
Hz centerFreq = Hz(5.18e9);
Hz bandwidth = Hz(20e6);
int numRUs = 2;

std::vector<Ieee80211HeRu> rus = calculateHeRus(centerFreq, bandwidth, numRUs);
EV << "Generated " << rus.size() << " RUs on " << (bandwidth.get() / 1e6) << " MHz channel\n";

for (const auto& ru : rus) {
    EV << "RU " << ru.index << ": freq=" << (ru.centerFrequency.get() / 1e9) << " GHz, "
       << "bw=" << (ru.bandwidth.get() / 1e6) << " MHz\n";
}

// Verify that RU center frequencies are different
if (rus[0].centerFrequency == rus[1].centerFrequency) {
    throw cRuntimeError("PHY-01 FAILED: RU center frequencies must be different but both are %.3f GHz",
                       rus[0].centerFrequency.get() / 1e9);
}
EV << "PHY-01 CHECK PASS: RU center frequencies differ\n";

// Verify that RU bandwidths are narrower than the total channel bandwidth
for (int i = 0; i < numRUs; i++) {
    if (rus[i].bandwidth >= bandwidth) {
        throw cRuntimeError("PHY-01 FAILED: RU %d bandwidth (%.1f MHz) must be less than total bandwidth (%.1f MHz)",
                           i, rus[i].bandwidth.get() / 1e6, bandwidth.get() / 1e6);
    }
}
EV << "PHY-01 CHECK PASS: All RU bandwidths narrower than total channel\n";

// Create two HE MU packets with RU tags
auto pkt1 = new Packet("MuSubPkt1");
pkt1->insertAtBack(makeShared<ByteCountChunk>(B(100)));

auto pkt2 = new Packet("MuSubPkt2");
pkt2->insertAtBack(makeShared<ByteCountChunk>(B(100)));

// Create main container packet for HE MU transmission
auto containerPkt = new Packet("MuContainer");
auto heMuTag = new Ieee80211HeMuTag();
heMuTag->addAllocation(0, pkt1);  // RU 0 for station 1
heMuTag->addAllocation(1, pkt2);  // RU 1 for station 2
containerPkt->addTag(heMuTag);
containerPkt->addTagIfAbsent<PacketProtocolTag>()->setProtocol(&Protocol::ieee80211HePhy);
containerPkt->insertAtBack(makeShared<ByteCountChunk>(B(200)));

// Create mock transmission with the tagged packet
auto mockTransmission = new MockIeee80211Transmission(radio1, containerPkt, mode, channel);

// Verify that the transmission carries the HE MU tag
auto foundTag = containerPkt->findTag<Ieee80211HeMuTag>();
if (!foundTag) {
    throw cRuntimeError("PHY-01 FAILED: HE MU tag not found on transmission packet");
}
if (foundTag->getAllocations().size() != numRUs) {
    throw cRuntimeError("PHY-01 FAILED: Tag allocation count %zu does not match RU count %d",
                       foundTag->getAllocations().size(), numRUs);
}
EV << "PHY-01 CHECK PASS: HE MU tag present with correct allocation count\n";

// Verify allocation list carries RU indices and packets
for (size_t i = 0; i < foundTag->getAllocations().size(); i++) {
    const auto& alloc = foundTag->getAllocations()[i];
    if (alloc.ruIndex < 0 || alloc.ruIndex >= numRUs) {
        throw cRuntimeError("PHY-01 FAILED: Allocation %zu has invalid RU index %d",
                           i, alloc.ruIndex);
    }
    if (!alloc.packet) {
        throw cRuntimeError("PHY-01 FAILED: Allocation %zu has null packet", i);
    }
}
EV << "PHY-01 CHECK PASS: All allocations have valid RU indices and packets\n";

// Summary
EV << "PHY-01 regression test PASSED: RU-band-specific attenuation metadata validated\n";
EV << ".\n";

delete mockTransmission;
delete channel;
delete nic1;
delete nic2;
