%description:
Test 802.11ax DL OFDMA sequential Block Ack steps, timeouts, and individual retry logic in HeDlMuTxOpFs.

%includes:
#include "inet/linklayer/common/MacAddress.h"
#include "inet/linklayer/ieee80211/mac/blockack/OriginatorBlockAckAgreement.h"
#include "inet/linklayer/ieee80211/mac/contract/IOriginatorBlockAckAgreementHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IFrameSequence.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceContext.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceStep.h"
#include "inet/linklayer/ieee80211/mac/framesequence/HeDlMuTxOpFs.h"
#include "inet/linklayer/ieee80211/mac/contract/IQosRateSelection.h"
#include "inet/linklayer/ieee80211/mac/contract/IAckHandler.h"
#include "inet/linklayer/ieee80211/mac/queue/InProgressFrames.h"
#include "inet/queueing/contract/IPacketQueue.h"

%file: TestNetwork.ned
import inet.queueing.queue.PacketQueue;

simple MockRateSelection
{
    @class(MockRateSelection);
}

module MockCallback
{
    parameters:
        @class(MockCallback);
    submodules:
        rateSelection: MockRateSelection;
}

network TestNetwork
{
    submodules:
        test: Test;
        mockHcf: MockCallback;
        pendingQueue: PacketQueue;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;

class MockRateSelection : public cSimpleModule, public IQosRateSelection
{
  public:
    virtual const physicallayer::IIeee80211Mode *computeResponseCtsFrameMode(Packet *packet, const Ptr<const Ieee80211RtsFrame>& rtsFrame) override { return nullptr; }
    virtual const physicallayer::IIeee80211Mode *computeResponseAckFrameMode(Packet *packet, const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
    virtual const physicallayer::IIeee80211Mode *computeResponseBlockAckFrameMode(Packet *packet, const Ptr<const Ieee80211BlockAckReq>& blockAckReq) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
    virtual const physicallayer::IIeee80211Mode *computeMode(Packet *packet, const Ptr<const Ieee80211MacHeader>& header, TxopProcedure *txopProcedure) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
};

Define_Module(MockRateSelection);

class MockAckHandler : public IAckHandler
{
  public:
    virtual bool isEligibleToTransmit(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return true; }
    virtual bool isOutstandingFrame(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return false; }
    virtual void frameGotInProgress(const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override {}
};

class MockScheduler : public IIeee80211HeDlScheduler
{
  public:
    virtual std::vector<RuAllocation> schedule(const std::vector<MacAddress>& candidateStations, Hz centerFrequency, Hz bandwidth) override {
        std::vector<RuAllocation> allocs;
        RuAllocation a1;
        a1.staAddress = MacAddress("00:11:22:33:44:55");
        a1.ru.index = 0;
        allocs.push_back(a1);

        RuAllocation a2;
        a2.staAddress = MacAddress("66:77:88:99:AA:BB");
        a2.ru.index = 1;
        allocs.push_back(a2);
        return allocs;
    }
};

class MockInProgressFrames : public InProgressFrames
{
  public:
    void addFrame(Packet *pkt) { inProgressFrames.push_back(pkt); }
};

class MockOriginatorBlockAckAgreementHandler : public IOriginatorBlockAckAgreementHandler
{
  public:
    std::vector<OriginatorBlockAckAgreement *> agreements;

    virtual ~MockOriginatorBlockAckAgreementHandler() {
        for (auto agreement : agreements)
            delete agreement;
    }

    void addAgreement(const MacAddress& receiver, Tid tid) {
        auto agreement = new OriginatorBlockAckAgreement(receiver, tid, SequenceNumberCyclic(0), 64, false, false);
        agreement->setIsAddbaResponseReceived(true);
        agreements.push_back(agreement);
    }

    virtual void processReceivedBlockAck(const Ptr<const Ieee80211BlockAck>& blockAck, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processTransmittedAddbaReq(const Ptr<const Ieee80211AddbaRequest>& addbaReq) override {}
    virtual void processTransmittedDataFrame(Packet *packet, const Ptr<const Ieee80211DataHeader>& dataHeader, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IProcedureCallback *callback) override {}
    virtual void processReceivedAddbaResp(const Ptr<const Ieee80211AddbaResponse>& addbaResp, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processReceivedDelba(const Ptr<const Ieee80211Delba>& delba, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy) override {}
    virtual void processTransmittedDelba(const Ptr<const Ieee80211Delba>& delba) override {}
    virtual void blockAckAgreementExpired(IProcedureCallback *procedureCallback, IBlockAckAgreementHandlerCallback *agreementHandlerCallback) override {}

    virtual OriginatorBlockAckAgreement *getAgreement(MacAddress receiverAddr, Tid tid) override {
        for (auto agreement : agreements) {
            if (agreement->getReceiverAddr() == receiverAddr && agreement->getTid() == tid)
                return agreement;
        }
        return nullptr;
    }
};

class MockCallback : public cSimpleModule, public IFrameSequenceHandler::ICallback
{
  public:
    int numFailedCalls = 0;
    virtual void transmitFrame(Packet *packet, simtime_t ifs) override {
        EV << "Callback: Transmitting " << packet->getName() << " with ifs " << ifs << "\n";
    }
    virtual void scheduleStartRxTimer(simtime_t timeout) override {
        EV << "Callback: StartRxTimer scheduled with timeout " << timeout << "\n";
    }
    virtual void originatorProcessTransmittedFrame(Packet *packet) override {
        EV << "Callback: ProcessTransmittedFrame " << packet->getName() << "\n";
    }
    virtual void originatorProcessReceivedFrame(Packet *receivedPacket, Packet *lastTransmittedPacket) override {
        EV << "Callback: ProcessReceivedFrame " << (receivedPacket ? receivedPacket->getName() : "nullptr") << "\n";
    }
    virtual void originatorProcessFailedFrame(Packet *failedPacket) override {
        EV << "Callback: ProcessFailedFrame " << failedPacket->getName() << "\n";
        numFailedCalls++;
    }
    virtual void originatorProcessRtsProtectionFailed(Packet *packet) override {}
    virtual void frameSequenceFinished() override {
        EV << "Callback: FrameSequenceFinished\n";
    }
};

Define_Module(MockCallback);

%activity:
auto mockHcf = check_and_cast<MockCallback *>(getParentModule()->getSubmodule("mockHcf"));
auto pendingQueue = check_and_cast<queueing::IPacketQueue *>(getParentModule()->getSubmodule("pendingQueue"));

// Create two packets for candidate STAs
MacAddress sta1("00:11:22:33:44:55");
MacAddress sta2("66:77:88:99:AA:BB");
Tid tid = 5;

Packet *p1 = new Packet("data-sta1");
auto hdr1 = makeShared<Ieee80211DataHeader>();
hdr1->setReceiverAddress(sta1);
hdr1->setType(ST_DATA_WITH_QOS);
hdr1->setTid(tid);
hdr1->setAckPolicy(BLOCK_ACK);
hdr1->setSequenceNumber(SequenceNumberCyclic(0));
p1->insertAtFront(hdr1);
pendingQueue->enqueuePacket(p1);

Packet *p2 = new Packet("data-sta2");
auto hdr2 = makeShared<Ieee80211DataHeader>();
hdr2->setReceiverAddress(sta2);
hdr2->setType(ST_DATA_WITH_QOS);
hdr2->setTid(tid);
hdr2->setAckPolicy(BLOCK_ACK);
hdr2->setSequenceNumber(SequenceNumberCyclic(1));
p2->insertAtFront(hdr2);
pendingQueue->enqueuePacket(p2);

auto modeSet = physicallayer::Ieee80211ModeSet::getModeSet("ax");
auto scheduler = new MockScheduler();
auto ackHandler = new MockAckHandler();

std::vector<MacAddress> candidates = {sta1, sta2};
HeDlMuTxOpFs *fs = new HeDlMuTxOpFs(scheduler, candidates, const_cast<physicallayer::Ieee80211ModeSet*>(modeSet), pendingQueue, ackHandler, mockHcf);

MockInProgressFrames *inProgress = new MockInProgressFrames();
MockOriginatorBlockAckAgreementHandler baHandler;
baHandler.addAgreement(sta1, tid);
baHandler.addAgreement(sta2, tid);
auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
FrameSequenceContext *context = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), const_cast<physicallayer::Ieee80211ModeSet*>(modeSet), inProgress, nullptr, nullptr, nullptr, qosContext);

fs->startSequence(context, 0);

// --- Step 0: Transmit container and lock sequential duration formula ---
IFrameSequenceStep *step0 = fs->prepareStep(context);
ASSERT(step0->getType() == IFrameSequenceStep::Type::TRANSMIT);
auto txStep0 = check_and_cast<ITransmitStep*>(step0);
Packet *containerPacket = txStep0->getFrameToTransmit();
ASSERT(containerPacket != nullptr);
EV << "Step 0 prepared: Transmit container frame.\n";

// Extract and verify container duration field
auto containerHdr = containerPacket->peekAtFront<Ieee80211DataHeader>();
ASSERT(containerHdr != nullptr);
simtime_t containerDuration = containerHdr->getDurationField();
EV << "Container duration field: " << containerDuration << "\n";

// Calculate expected duration per phase 2 sequential formula:
// D-02: First response = SIFS + basic Block Ack duration
// D-03: Each additional response = SIFS + BAR(38) + SIFS + basic Block Ack duration
auto rateSelection = check_and_cast<IQosRateSelection *>(mockHcf->getSubmodule("rateSelection"));
auto dummyReq = makeShared<Ieee80211BasicBlockAckReq>();
auto responseMode = rateSelection->computeResponseBlockAckFrameMode(containerPacket, dummyReq);
simtime_t blockAckDuration = responseMode->getDuration(LENGTH_BASIC_BLOCKACK);
simtime_t barDuration = responseMode->getDuration(B(38));
simtime_t sifsTime = modeSet->getSifsTime();

// For 2 STAs: SIFS + blockAck + (SIFS + BAR + SIFS + blockAck)
simtime_t expectedDuration = sifsTime + blockAckDuration + (sifsTime + barDuration + sifsTime + blockAckDuration);
EV << "Expected duration: " << expectedDuration << "\n";
EV << "SIFS=, BlockAck=, BAR=\n";
EV << "  SIFS=" << sifsTime << ", BlockAck=" << blockAckDuration << ", BAR=" << barDuration << "\n";
ASSERT(containerDuration == expectedDuration);

context->addStep(step0);
fs->completeStep(context);

// --- Step 1: Expect Block Ack from STA 1 with explicit timeout calculation ---
IFrameSequenceStep *step1 = fs->prepareStep(context);
ASSERT(step1->getType() == IFrameSequenceStep::Type::RECEIVE);
auto rxStep1 = check_and_cast<IReceiveStep*>(step1);
EV << "Step 1 prepared: Expect Block Ack with timeout.\n";

// Verify timeout window per D-05: SIFS + basic Block Ack duration + slotTime
simtime_t expectedTimeout1 = sifsTime + blockAckDuration + modeSet->getSlotTime();
EV << "Expected timeout for step 1: " << expectedTimeout1 << "\n";

context->addStep(step1);

// Simulate successful Block Ack reception from STA 1
Packet *ack1 = new Packet("BasicBlockAck");
auto ackHdr1 = makeShared<Ieee80211BasicBlockAck>();
ackHdr1->setReceiverAddress(MacAddress("AA:BB:CC:DD:EE:FF"));
ack1->insertAtFront(ackHdr1);
rxStep1->setFrameToReceive(ack1);

fs->completeStep(context);

// --- Step 2: Transmit BAR to STA 2 ---
IFrameSequenceStep *step2 = fs->prepareStep(context);
ASSERT(step2->getType() == IFrameSequenceStep::Type::TRANSMIT);
auto txStep2 = check_and_cast<ITransmitStep*>(step2);
Packet *barPacket = txStep2->getFrameToTransmit();
ASSERT(barPacket != nullptr);
EV << "Step 2 prepared: Transmit BAR frame.\n";

// Record BAR packet duration field evidence for the sequential exchange.
auto barHdr = barPacket->peekAtFront<Ieee80211MacHeader>();
simtime_t barPktDuration = barHdr->getDurationField();
EV << "BAR packet duration field: " << barPktDuration << "\n";

context->addStep(step2);

fs->completeStep(context);

// --- Step 3: Expect Block Ack from STA 2 with explicit timeout calculation ---
IFrameSequenceStep *step3 = fs->prepareStep(context);
ASSERT(step3->getType() == IFrameSequenceStep::Type::RECEIVE);
auto rxStep3 = check_and_cast<IReceiveStep*>(step3);
EV << "Step 3 prepared: Expect Block Ack with timeout.\n";

// Verify timeout window per D-05: SIFS + basic Block Ack duration + slotTime
simtime_t expectedTimeout3 = sifsTime + blockAckDuration + modeSet->getSlotTime();
EV << "Expected timeout for step 3: " << expectedTimeout3 << "\n";

context->addStep(step3);

// --- Wave 2: Prove recoverable timeout behavior (D-06, D-07) ---
// Simulate timeout (no frame received) to test recovery path
EV << "Step 3: Simulating timeout (missing Block Ack) to verify recovery path.\n";
rxStep3->setFrameToReceive(nullptr);

// Record initial failure count before timeout handling
int failureCountBefore = mockHcf->numFailedCalls;
EV << "Failures before timeout handling: " << failureCountBefore << "\n";

fs->completeStep(context);

// Verify that the timeout was handled as a rejection (D-06) not an abort
int failureCountAfter = mockHcf->numFailedCalls;
ASSERT(failureCountAfter > failureCountBefore);
EV << "Timeout marked current receive step as rejected. Failures after: " << failureCountAfter << "\n";

// --- Step 4: Verify sequence continues cleanly (D-06, D-07) ---
IFrameSequenceStep *step4 = fs->prepareStep(context);
if (step4 != nullptr) {
    EV << "Step 4 exists: " << static_cast<int>(step4->getType()) << "\n";
    // If there's a Step 4, verify it respects SIFS spacing (D-07)
    if (step4->getType() == IFrameSequenceStep::Type::TRANSMIT) {
        auto txStep4 = check_and_cast<ITransmitStep*>(step4);
        simtime_t ifs4 = context->getIfs();
        EV << "Step 4 inter-frame spacing (should be SIFS per D-07): " << ifs4 << " (expected: " << sifsTime << ")\n";
        ASSERT(ifs4 == sifsTime);
    }
    context->addStep(step4);
    fs->completeStep(context);
    
    // Continue until sequence ends
    IFrameSequenceStep *stepFinal = fs->prepareStep(context);
    ASSERT(stepFinal == nullptr);
}
else {
    // Sequence ends after timeout rejection - this is also valid
    EV << "Sequence ended cleanly after timeout rejection.\n";
}

EV << "Failed calls count: " << mockHcf->numFailedCalls << "\n";

delete scheduler;
delete ackHandler;
delete fs;
delete context;
delete inProgress;

%contains: stdout
Step 0 prepared: Transmit container frame.
Container duration field: 0.000556
Expected duration: 0.000556
SIFS=, BlockAck=, BAR=
  SIFS=0.000016, BlockAck=0.000212, BAR=0.000084
Step 1 prepared: Expect Block Ack with timeout.
Expected timeout for step 1: 0.000237
Callback: ProcessReceivedFrame BasicBlockAck
Step 2 prepared: Transmit BAR frame.
BAR packet duration field: -1
Step 3 prepared: Expect Block Ack with timeout.
Expected timeout for step 3: 0.000237
Step 3: Simulating timeout (missing Block Ack) to verify recovery path.
Failures before timeout handling: 0
HeDlMuTxOpFs: sequential BlockAck timeout for STA 66-77-88-99-AA-BB, triggering failure recovery.
Callback: ProcessFailedFrame data-sta2
Timeout marked current receive step as rejected. Failures after: 1
Sequence ended cleanly after timeout rejection.
Failed calls count: 1
