%description:
Test that Ieee80211RadioMedium keeps an HE MU OFDMA PPDU as one transmission
while computing assigned receiver reception on the selected RU.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211RadioMedium.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Transmission.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeMuUtil.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211Band.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211ModeSet.h"
#include "inet/physicallayer/wireless/common/base/packetlevel/FlatTransmitterBase.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/IScalarSignalAnalogModel.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/networklayer/common/NetworkInterface.h"
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/Protocol.h"
#include "inet/common/packet/Packet.h"

%file: TestNetwork.ned
import inet.networklayer.common.InterfaceTable;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211RadioMedium;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211ScalarRadio;
import inet.mobility.static.StationaryMobility;

module InspectableRadioMedium extends Ieee80211RadioMedium
{
    parameters:
        @class(InspectableRadioMedium);
}

module MockNic
{
    parameters:
        @class(MockNicModule);
    submodules:
        radio: Ieee80211ScalarRadio {
            parameters:
                transmitter.power = 20mW;
        }
    connections allowunconnected:
        radio.upperLayerOut --> radio.upperLayerIn;
}

network TestNetwork
{
    parameters:
        @networkNode;
    submodules:
        test: Test;
        interfaceTable: InterfaceTable;
        radioMedium: InspectableRadioMedium {
            parameters:
                sameTransmissionStartTimeCheck = "ignore";
        }
        mobility: StationaryMobility;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork
**.nic*.interfaceTableModule = "^.interfaceTable"
**.mobilityModule = "^.^.^.mobility"
**.mobility.subjectModule = ""
**.radio.opMode = "ax"
**.radio.bandName = "5 GHz (20 MHz)"
**.radio.channelNumber = 0
**.radio.transmitter.bitrate = 7.3125Mbps
**.radio.transmitter.power = 20mW
**.constraintAreaMinX = 0m
**.constraintAreaMinY = 0m
**.constraintAreaMinZ = 0m
**.constraintAreaMaxX = 100m
**.constraintAreaMaxY = 100m
**.constraintAreaMaxZ = 0m

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;

class InspectableRadioMedium : public Ieee80211RadioMedium
{
  public:
    void testAddTransmission(const IRadio *transmitter, const ITransmission *transmission) { addTransmission(transmitter, transmission); }
    void testRemoveTransmission(const ITransmission *transmission) { removeTransmission(transmission); }
    const IReception *testComputeReception(const IRadio *receiver, const ITransmission *transmission) const { return computeReception(receiver, transmission); }
};

class MockNicModule : public NetworkInterface
{
  protected:
    virtual void initialize(int stage) override {
        if (stage == INITSTAGE_LOCAL) {
            state = UP;
            carrier = true;
        }
    }
    virtual int numInitStages() const override { return 1; }
};

Define_Module(InspectableRadioMedium);
Define_Module(MockNicModule);

static Packet *makeDataPacket(const char *name, const MacAddress& receiver)
{
    auto packet = new Packet(name);
    auto header = makeShared<Ieee80211DataHeader>();
    header->setType(ST_DATA_WITH_QOS);
    header->setReceiverAddress(receiver);
    header->setTransmitterAddress(MacAddress("AA:BB:CC:DD:EE:FF"));
    header->setAckPolicy(BLOCK_ACK);
    header->setTid(5);
    header->setChunkLength(b(288));
    packet->insertAtFront(header);
    packet->insertAtBack(makeShared<ByteCountChunk>(B(100)));
    auto trailer = makeShared<Ieee80211MacTrailer>();
    trailer->setChunkLength(B(4));
    packet->insertAtBack(trailer);
    return packet;
}

%activity:
cModuleType *nicType = cModuleType::find("MockNic");
if (nicType == nullptr)
    throw cRuntimeError("Could not find MockNic module type");

cModule *txNic = nicType->create("txNic", getSystemModule());
txNic->buildInside();
auto txNetIface = check_and_cast<MockNicModule *>(txNic);
txNetIface->setMacAddress(MacAddress("AA:BB:CC:DD:EE:FF"));
txNic->callInitialize();

cModule *rxNic = nicType->create("rxNic", getSystemModule());
rxNic->buildInside();
auto rxNetIface = check_and_cast<MockNicModule *>(rxNic);
rxNetIface->setMacAddress(MacAddress("00:11:22:33:44:55"));
rxNic->callInitialize();

auto medium = check_and_cast<InspectableRadioMedium *>(getParentModule()->getSubmodule("radioMedium"));
auto txRadio = check_and_cast<IRadio *>(txNic->getSubmodule("radio"));
auto rxRadio = check_and_cast<IRadio *>(rxNic->getSubmodule("radio"));

auto modeSet = Ieee80211ModeSet::getModeSet("ax");
auto mode = const_cast<Ieee80211ModeSet *>(modeSet)->getMode(0);
auto band = Ieee80211CompliantBands::getBand("5 GHz");
auto channel = new Ieee80211Channel(band, 0);
Hz centerFreq = channel->getCenterFrequency();
Hz bandwidth = mode->getDataMode()->getBandwidth();
auto rus = calculateHeRus(centerFreq, bandwidth, 4);

MacAddress sta1("00:11:22:33:44:55");
MacAddress sta2("66:77:88:99:AA:BB");
MacAddress sta3("02:00:00:00:00:03");

auto container = new Packet("HE-MU-PPDU");
auto phyHeader = makeShared<Ieee80211HeMuPhyHeader>();
auto appendUser = [&] (const Ieee80211HeRu& ru, const MacAddress& sta) {
    Ieee80211HeMuUserInfo user;
    user.ruIndex = ru.index;
    user.ruToneSize = ru.toneSize;
    user.ruToneOffset = ru.toneOffset;
    user.staId = computeHeMuStaId(sta);
    phyHeader->appendUsers(user);
};
appendUser(rus[0], sta1);
appendUser(rus[1], sta2);
appendUser(rus[2], sta3);
phyHeader->setChunkLength(b(16 + phyHeader->getUsersArraySize() * 73));
container->insertAtBack(phyHeader);
auto containerHdr = makeShared<Ieee80211DataHeader>();
containerHdr->setReceiverAddress(MacAddress::BROADCAST_ADDRESS);
containerHdr->setType(ST_DATA_WITH_QOS);
containerHdr->setChunkLength(b(288));
container->insertAtBack(containerHdr);
auto appendPayload = [&] (const Ieee80211HeRu& ru, const MacAddress& sta, const char *name) {
    auto mpdu = makeDataPacket(name, sta);
    auto payloadHeader = makeShared<Ieee80211HeMuRuPayloadHeader>();
    payloadHeader->setRuIndex(ru.index);
    payloadHeader->setRuToneSize(ru.toneSize);
    payloadHeader->setRuToneOffset(ru.toneOffset);
    payloadHeader->setStaId(computeHeMuStaId(sta));
    payloadHeader->setMpduLength(B(mpdu->getByteLength()));
    container->insertAtBack(payloadHeader);
    container->insertAtBack(mpdu->peekData());
    delete mpdu;
};
appendPayload(rus[0], sta1, "ru0-data");
appendPayload(rus[1], sta2, "ru1-data");
appendPayload(rus[2], sta3, "ru2-data");
container->insertAtBack(makeShared<Ieee80211MacTrailer>());

auto flatTransmitter = check_and_cast<const FlatTransmitterBase *>(txRadio->getTransmitter());
auto analogModel = flatTransmitter->getAnalogModel()->createAnalogModel(
        SimTime(100, SIMTIME_US),
        SimTime(100, SIMTIME_US),
        SimTime(800, SIMTIME_US),
        centerFreq,
        bandwidth,
        flatTransmitter->getPower());

auto transmission = new Ieee80211Transmission(
        txRadio,
        container,
        SIMTIME_ZERO,
        SimTime(1, SIMTIME_MS),
        SimTime(100, SIMTIME_US),
        SimTime(100, SIMTIME_US),
        SimTime(800, SIMTIME_US),
        Coord(), Coord(),
        Quaternion(), Quaternion(),
        nullptr, nullptr, nullptr, nullptr,
        analogModel,
        mode,
        channel);

medium->testAddTransmission(txRadio, transmission);
ASSERT(medium->getCommunicationCache()->getNumTransmissions() == 1);

auto aggregateAnalog = check_and_cast<const IScalarSignalAnalogModel *>(transmission->getAnalogModel());
ASSERT(aggregateAnalog->getCenterFrequency() == centerFreq);
ASSERT(aggregateAnalog->getBandwidth() == bandwidth);

auto reception = medium->testComputeReception(rxRadio, transmission);
auto ruReceptionAnalog = check_and_cast<const IScalarSignalAnalogModel *>(reception->getAnalogModel());
ASSERT(ruReceptionAnalog->getCenterFrequency() == rus[0].centerFrequency);
ASSERT(ruReceptionAnalog->getBandwidth() == rus[0].bandwidth);
ASSERT(ruReceptionAnalog->getPower() < aggregateAnalog->getPower());

delete reception;
medium->testRemoveTransmission(transmission);
delete channel;
txNic->deleteModule();
rxNic->deleteModule();

EV << "Ieee80211RadioMedium kept HE MU OFDMA as one PPDU transmission.\n";
EV << "Assigned receiver reception used the selected RU center frequency and bandwidth.\n";
EV << ".\n";

%contains: stdout
Ieee80211RadioMedium kept HE MU OFDMA as one PPDU transmission.
Assigned receiver reception used the selected RU center frequency and bandwidth.
.
