%description:
Test that Ieee80211RadioMedium turns an HE MU container into per-RU sub-transmissions
and preserves the receiver-visible PHY metadata.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211RadioMedium.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Transmission.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeMuTag.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211Band.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211ModeSet.h"
#include "inet/physicallayer/wireless/common/base/packetlevel/FlatTransmitterBase.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/IReception.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/IScalarSignalAnalogModel.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/networklayer/common/NetworkInterface.h"
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/Protocol.h"
#include "inet/common/packet/Packet.h"

%file: TestNetwork.ned
import inet.networklayer.common.InterfaceTable;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211RadioMedium;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211ScalarRadio;
import inet.mobility.static.StationaryMobility;

module InspectableRadioMedium extends Ieee80211RadioMedium
{
    parameters:
        @class(InspectableRadioMedium);
}

module MockNic
{
    parameters:
        @class(MockNicModule);
    submodules:
        radio: Ieee80211ScalarRadio {
            parameters:
                transmitter.power = 20mW;
        }
    connections allowunconnected:
        radio.upperLayerOut --> radio.upperLayerIn;
}

network TestNetwork
{
    parameters:
        @networkNode;
    submodules:
        test: Test;
        interfaceTable: InterfaceTable;
        radioMedium: InspectableRadioMedium {
            parameters:
                sameTransmissionStartTimeCheck = "ignore";
        }
        mobility: StationaryMobility;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork
**.nic*.interfaceTableModule = "^.interfaceTable"
**.mobilityModule = "^.^.^.mobility"
**.mobility.subjectModule = ""
**.radio.opMode = "ax"
**.radio.bandName = "5 GHz (20 MHz)"
**.radio.channelNumber = 0
**.radio.transmitter.bitrate = 7.3125Mbps
**.radio.transmitter.power = 20mW
**.constraintAreaMinX = 0m
**.constraintAreaMinY = 0m
**.constraintAreaMinZ = 0m
**.constraintAreaMaxX = 100m
**.constraintAreaMaxY = 100m
**.constraintAreaMaxZ = 0m

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;

class InspectableRadioMedium : public Ieee80211RadioMedium
{
  public:
    void testAddTransmission(const IRadio *transmitter, const ITransmission *transmission) { addTransmission(transmitter, transmission); }
    void testRemoveTransmission(const ITransmission *transmission) { removeTransmission(transmission); }
    bool testIsPotentialReceiver(const IRadio *receiver, const ITransmission *transmission) const { return isPotentialReceiver(receiver, transmission); }
    bool testIsInterferingTransmission(const ITransmission *transmission, const IReception *reception) const { return isInterferingTransmission(transmission, reception); }
    int getSubTransmissionCount(const ITransmission *transmission) const {
        auto it = muSubTransmissions.find(transmission);
        return it == muSubTransmissions.end() ? 0 : it->second.size();
    }
    const ITransmission *getSubTransmission(const ITransmission *transmission, int index) const {
        auto it = muSubTransmissions.find(transmission);
        if (it == muSubTransmissions.end())
            throw cRuntimeError("No sub-transmissions for inspected transmission");
        return it->second.at(index);
    }
};

class MockNicModule : public NetworkInterface
{
  protected:
    virtual void initialize(int stage) override {
        if (stage == INITSTAGE_LOCAL) {
            state = UP;
            carrier = true;
        }
    }
    virtual int numInitStages() const override { return 1; }
};

class MockReception : public IReception
{
  protected:
    const IRadio *receiver = nullptr;
    const ITransmission *transmission = nullptr;
    Coord position;
    Quaternion orientation;

  public:
    MockReception(const IRadio *receiver, const ITransmission *transmission) : receiver(receiver), transmission(transmission) {}
    virtual std::ostream& printToStream(std::ostream& stream, int level, int evFlags = 0) const override { return stream << "MockReception"; }
    virtual const IRadio *getReceiverRadio() const override { return receiver; }
    virtual const ITransmission *getTransmission() const override { return transmission; }
    virtual const simtime_t getStartTime() const override { return transmission->getStartTime(); }
    virtual const simtime_t getEndTime() const override { return transmission->getEndTime(); }
    virtual const simtime_t getStartTime(IRadioSignal::SignalPart part) const override { return transmission->getStartTime(part); }
    virtual const simtime_t getEndTime(IRadioSignal::SignalPart part) const override { return transmission->getEndTime(part); }
    virtual const simtime_t getPreambleStartTime() const override { return transmission->getPreambleStartTime(); }
    virtual const simtime_t getPreambleEndTime() const override { return transmission->getPreambleEndTime(); }
    virtual const simtime_t getHeaderStartTime() const override { return transmission->getHeaderStartTime(); }
    virtual const simtime_t getHeaderEndTime() const override { return transmission->getHeaderEndTime(); }
    virtual const simtime_t getDataStartTime() const override { return transmission->getDataStartTime(); }
    virtual const simtime_t getDataEndTime() const override { return transmission->getDataEndTime(); }
    virtual const simtime_t getDuration() const override { return transmission->getDuration(); }
    virtual const simtime_t getDuration(IRadioSignal::SignalPart part) const override { return transmission->getDuration(part); }
    virtual const simtime_t getPreambleDuration() const override { return transmission->getPreambleDuration(); }
    virtual const simtime_t getHeaderDuration() const override { return transmission->getHeaderDuration(); }
    virtual const simtime_t getDataDuration() const override { return transmission->getDataDuration(); }
    virtual const Coord& getStartPosition() const override { return position; }
    virtual const Coord& getEndPosition() const override { return position; }
    virtual const Quaternion& getStartOrientation() const override { return orientation; }
    virtual const Quaternion& getEndOrientation() const override { return orientation; }
    virtual const IReceptionAnalogModel *getAnalogModel() const override { return nullptr; }
};

Define_Module(InspectableRadioMedium);
Define_Module(MockNicModule);

static Packet *makeDataPacket(const char *name, const MacAddress& receiver)
{
    auto packet = new Packet(name);
    auto header = makeShared<Ieee80211DataHeader>();
    header->setType(ST_DATA_WITH_QOS);
    header->setReceiverAddress(receiver);
    header->setTransmitterAddress(MacAddress("AA:BB:CC:DD:EE:FF"));
    header->setAckPolicy(BLOCK_ACK);
    header->setTid(5);
    header->setChunkLength(b(288));
    packet->insertAtFront(header);
    packet->insertAtBack(makeShared<ByteCountChunk>(B(100)));
    auto trailer = makeShared<Ieee80211MacTrailer>();
    trailer->setChunkLength(B(4));
    packet->insertAtBack(trailer);
    return packet;
}

%activity:
cModuleType *nicType = cModuleType::find("MockNic");
if (nicType == nullptr)
    throw cRuntimeError("Could not find MockNic module type");

cModule *txNic = nicType->create("txNic", getSystemModule());
txNic->buildInside();
auto txNetIface = check_and_cast<MockNicModule *>(txNic);
txNetIface->setMacAddress(MacAddress("AA:BB:CC:DD:EE:FF"));
txNic->callInitialize();

cModule *rxNic = nicType->create("rxNic", getSystemModule());
rxNic->buildInside();
auto rxNetIface = check_and_cast<MockNicModule *>(rxNic);
rxNetIface->setMacAddress(MacAddress("00:11:22:33:44:55"));
rxNic->callInitialize();

auto medium = check_and_cast<InspectableRadioMedium *>(getParentModule()->getSubmodule("radioMedium"));
auto txRadio = check_and_cast<IRadio *>(txNic->getSubmodule("radio"));
auto rxRadio = check_and_cast<IRadio *>(rxNic->getSubmodule("radio"));

auto modeSet = Ieee80211ModeSet::getModeSet("ax");
auto mode = const_cast<Ieee80211ModeSet *>(modeSet)->getMode(0);
auto band = Ieee80211CompliantBands::getBand("5 GHz");
auto channel = new Ieee80211Channel(band, 0);

MacAddress sta1("00:11:22:33:44:55");
MacAddress sta2("66:77:88:99:AA:BB");
MacAddress sta3("02:00:00:00:00:03");

auto container = new Packet("HE-MU-PPDU");
auto heMuTag = container->addTag<Ieee80211HeMuTag>();
heMuTag->addAllocation(0, makeDataPacket("ru0-data", sta1));
heMuTag->addAllocation(1, makeDataPacket("ru1-data", sta2));
heMuTag->addAllocation(2, makeDataPacket("ru2-data", sta3));
container->insertAtBack(makeShared<ByteCountChunk>(B(32)));

auto transmission = new Ieee80211Transmission(
        txRadio,
        container,
        SIMTIME_ZERO,
        SimTime(1, SIMTIME_MS),
        SimTime(100, SIMTIME_US),
        SimTime(100, SIMTIME_US),
        SimTime(800, SIMTIME_US),
        Coord(), Coord(),
        Quaternion(), Quaternion(),
        nullptr, nullptr, nullptr, nullptr,
        nullptr,
        mode,
        channel);

medium->testAddTransmission(txRadio, transmission);
ASSERT(medium->getSubTransmissionCount(transmission) == 3);
ASSERT(!medium->testIsPotentialReceiver(rxRadio, transmission));

auto totalPower = check_and_cast<const FlatTransmitterBase *>(txRadio->getTransmitter())->getPower();
W accumulatedPower = W(0);
std::set<int> ruIndices;
std::vector<const ITransmission *> subTransmissions;

for (int i = 0; i < 3; i++) {
    auto subTransmission = medium->getSubTransmission(transmission, i);
    subTransmissions.push_back(subTransmission);
    auto subPacket = subTransmission->getPacket();
    ASSERT(subPacket != nullptr);
    ASSERT(subPacket->getTag<PacketProtocolTag>()->getProtocol() == &Protocol::ieee80211HePhy);

    auto phyHeader = subPacket->peekAtFront<Ieee80211HeMuPhyHeader>();
    ASSERT(phyHeader != nullptr);
    ASSERT(phyHeader->getRuIndex() == i);
    ASSERT(phyHeader->getAllocationsArraySize() == 3);
    ASSERT(phyHeader->getAllocations(i).ruIndex == i);
    ASSERT(ruIndices.insert(phyHeader->getRuIndex()).second);

    auto trailer = subPacket->peekAtBack<Ieee80211MacTrailer>(B(4));
    ASSERT(trailer->getFcsMode() == FCS_DECLARED_CORRECT);

    auto scalarAnalog = dynamic_cast<const IScalarSignalAnalogModel *>(subTransmission->getAnalogModel());
    ASSERT(scalarAnalog != nullptr);
    accumulatedPower = accumulatedPower + scalarAnalog->getPower();
}

ASSERT(ruIndices.size() == 3);
ASSERT(std::abs(accumulatedPower.get() - totalPower.get()) < totalPower.get() * 0.01);

MockReception siblingReception(rxRadio, subTransmissions[1]);
ASSERT(!medium->testIsInterferingTransmission(subTransmissions[0], &siblingReception));

medium->testRemoveTransmission(transmission);
delete channel;
txNic->deleteModule();
rxNic->deleteModule();

EV << "Ieee80211RadioMedium split HE MU container into 3 RU sub-transmissions.\n";
EV << "Sub-transmissions carried HE MU PHY headers, full allocation maps, declared-correct FCS, and conserved scalar power.\n";
EV << "Main MU container was not a physical receiver candidate and sibling RUs did not interfere.\n";
EV << ".\n";

%contains: stdout
Ieee80211RadioMedium split HE MU container into 3 RU sub-transmissions.
Sub-transmissions carried HE MU PHY headers, full allocation maps, declared-correct FCS, and conserved scalar power.
Main MU container was not a physical receiver candidate and sibling RUs did not interfere.
.
