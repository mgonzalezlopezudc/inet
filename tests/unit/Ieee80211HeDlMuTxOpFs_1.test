%description:
Test HeDlMuTxOpFs TXOP trimming, BA-window exhaustion, per-user packing, and fallback below two users.

%includes:
#include <map>
#include <set>

#include "inet/common/packet/chunk/ByteCountChunk.h"
#include "inet/linklayer/common/MacAddress.h"
#include "inet/linklayer/ieee80211/mac/blockack/OriginatorBlockAckAgreement.h"
#include "inet/linklayer/ieee80211/mac/contract/IAckHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IFrameSequence.h"
#include "inet/linklayer/ieee80211/mac/contract/IFrameSequenceHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IOriginatorBlockAckAgreementHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IQosRateSelection.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceContext.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceStep.h"
#include "inet/linklayer/ieee80211/mac/framesequence/HeDlMuPackingPlanner.h"
#include "inet/linklayer/ieee80211/mac/framesequence/HeDlMuTxOpFs.h"
#include "inet/linklayer/ieee80211/mac/queue/InProgressFrames.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HePhyCalculator.h"
#include "inet/queueing/contract/IPacketQueue.h"

%file: TestNetwork.ned
import inet.queueing.queue.PacketQueue;

simple MockDlMuRateSelection
{
    parameters:
        @class(MockDlMuRateSelection);
}

module MockDlMuCallback
{
    parameters:
        @class(MockDlMuCallback);
    submodules:
        rateSelection: MockDlMuRateSelection;
}

network TestNetwork
{
    submodules:
        test: Test;
        mockHcf: MockDlMuCallback;
        pendingQueue: PacketQueue;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork
allow-object-stealing-on-deletion = true

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;
using namespace inet::units::values;

class MockDlMuRateSelection : public cSimpleModule, public IQosRateSelection
{
  protected:
    const IIeee80211Mode *getSlowHeMode() const
    {
        auto modeSet = const_cast<Ieee80211ModeSet *>(Ieee80211ModeSet::getModeSet("ax"));
        return modeSet->getMode(0);
    }

  public:
    virtual const IIeee80211Mode *computeResponseCtsFrameMode(Packet *packet, const Ptr<const Ieee80211RtsFrame>& rtsFrame) override { return nullptr; }
    virtual const IIeee80211Mode *computeResponseAckFrameMode(Packet *packet, const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override { return getSlowHeMode(); }
    virtual const IIeee80211Mode *computeResponseBlockAckFrameMode(Packet *packet, const Ptr<const Ieee80211BlockAckReq>& blockAckReq) override { return getSlowHeMode(); }
    virtual const IIeee80211Mode *computeMode(Packet *packet, const Ptr<const Ieee80211MacHeader>& header, TxopProcedure *txopProcedure) override { return getSlowHeMode(); }
};

Define_Module(MockDlMuRateSelection);

class MockDlMuCallback : public cSimpleModule, public IFrameSequenceHandler::ICallback
{
  public:
    virtual void transmitFrame(Packet *packet, simtime_t ifs) override {}
    virtual void scheduleStartRxTimer(simtime_t timeout) override {}
    virtual void originatorProcessTransmittedFrame(Packet *packet) override {}
    virtual void originatorProcessReceivedFrame(Packet *receivedPacket, Packet *lastTransmittedPacket) override {}
    virtual void originatorProcessFailedFrame(Packet *failedPacket) override {}
    virtual void originatorProcessRtsProtectionFailed(Packet *packet) override {}
    virtual void frameSequenceFinished() override {}
};

Define_Module(MockDlMuCallback);

class MockDlMuAckHandler : public IAckHandler
{
  public:
    int inProgressCount = 0;
    std::map<std::pair<MacAddress, Tid>, std::set<int>> occupied;

    virtual bool isEligibleToTransmit(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return true; }
    virtual bool isOutstandingFrame(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return false; }
    virtual void frameGotInProgress(const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override { inProgressCount++; }
    virtual std::set<int> getOccupiedBlockAckSequenceNumbers(const MacAddress& receiverAddress, Tid tid) const override
    {
        auto it = occupied.find({receiverAddress, tid});
        return it == occupied.end() ? std::set<int>() : it->second;
    }
};

class MockDlMuScheduler : public IIeee80211HeDlScheduler
{
  public:
    std::vector<RuAllocation> allocations;

    MockDlMuScheduler(const std::vector<RuAllocation>& allocations) : allocations(allocations) {}

    virtual std::vector<RuAllocation> schedule(const std::vector<MacAddress>& candidates, Hz centerFrequency, Hz bandwidth) override { return allocations; }
    virtual std::vector<RuAllocation> schedule(const ScheduleContext& context) override { return allocations; }
};

class MockDlMuInProgressFrames : public InProgressFrames
{
};

class MockDlMuOriginatorBlockAckAgreementHandler : public IOriginatorBlockAckAgreementHandler
{
  public:
    std::vector<OriginatorBlockAckAgreement *> agreements;

    virtual ~MockDlMuOriginatorBlockAckAgreementHandler()
    {
        for (auto agreement : agreements)
            delete agreement;
    }

    void addAgreement(const MacAddress& receiver, Tid tid, int bufferSize = 64)
    {
        auto agreement = new OriginatorBlockAckAgreement(receiver, tid, SequenceNumberCyclic(0), bufferSize, false, false);
        agreement->setIsAddbaResponseReceived(true);
        agreements.push_back(agreement);
    }

    virtual void processReceivedBlockAck(const Ptr<const Ieee80211BlockAck>& blockAck, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processTransmittedAddbaReq(const Ptr<const Ieee80211AddbaRequest>& addbaReq) override {}
    virtual void processTransmittedDataFrame(Packet *packet, const Ptr<const Ieee80211DataHeader>& dataHeader, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IProcedureCallback *callback) override {}
    virtual void processReceivedAddbaResp(const Ptr<const Ieee80211AddbaResponse>& addbaResp, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processReceivedDelba(const Ptr<const Ieee80211Delba>& delba, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy) override {}
    virtual void processTransmittedDelba(const Ptr<const Ieee80211Delba>& delba) override {}
    virtual void blockAckAgreementExpired(IProcedureCallback *procedureCallback, IBlockAckAgreementHandlerCallback *agreementHandlerCallback) override {}

    virtual OriginatorBlockAckAgreement *getAgreement(MacAddress receiverAddr, Tid tid) override
    {
        for (auto agreement : agreements)
            if (agreement->getReceiverAddr() == receiverAddr && agreement->getTid() == tid)
                return agreement;
        return nullptr;
    }
};

static Ieee80211HeRu makeRu(int index, int toneSize = 26)
{
    Ieee80211HeRu ru;
    ru.index = index;
    ru.toneSize = toneSize;
    ru.dataSubcarriers = getHeRuDataSubcarrierCount(toneSize);
    ru.pilotSubcarriers = getHeRuPilotSubcarrierCount(toneSize);
    ru.bandwidth = Hz(toneSize * 78125.0);
    return ru;
}

static IIeee80211HeDlScheduler::RuAllocation makeAllocation(const MacAddress& sta, int index, int toneSize = 26)
{
    IIeee80211HeDlScheduler::RuAllocation allocation;
    allocation.staAddress = sta;
    allocation.ru = makeRu(index, toneSize);
    allocation.mcs = 0;
    allocation.numberOfSpatialStreams = 1;
    allocation.estimatedDuration = SimTime(3, SIMTIME_MS);
    return allocation;
}

static void requireTrue(bool condition, const char *message)
{
    if (!condition)
        throw cRuntimeError("%s", message);
}

static void clearQueue(queueing::IPacketQueue *queue)
{
    while (queue->getNumPackets() > 0) {
        auto packet = queue->getPacket(0);
        queue->removePacket(packet);
        delete packet;
    }
}

static IIeee80211HeDlScheduler::ScheduleContext makeScheduleContext(const std::vector<MacAddress>& stations, simtime_t txopLimit = SIMTIME_ZERO)
{
    IIeee80211HeDlScheduler::ScheduleContext context;
    context.channelCenterFrequency = Hz(5.18e9);
    context.channelBandwidth = Hz(20e6);
    context.txopLimit = txopLimit;
    for (size_t i = 0; i < stations.size(); i++) {
        IIeee80211HeDlScheduler::CandidateInfo candidate;
        candidate.staAddress = stations[i];
        candidate.anchor = i == 0;
        context.candidates.push_back(candidate);
    }
    if (!stations.empty())
        context.anchorSta = stations.front();
    return context;
}

static Packet *makeDataPacket(const char *name, const MacAddress& receiver, Tid tid, int sequenceNumber, int payloadBytes)
{
    auto packet = new Packet(name);
    auto header = makeShared<Ieee80211DataHeader>();
    header->setReceiverAddress(receiver);
    header->setType(ST_DATA_WITH_QOS);
    header->setTid(tid);
    header->setAckPolicy(BLOCK_ACK);
    header->setSequenceNumber(SequenceNumberCyclic(sequenceNumber));
    packet->insertAtFront(header);
    if (payloadBytes > 0)
        packet->insertAtBack(makeShared<ByteCountChunk>(B(payloadBytes)));
    packet->insertAtBack(makeShared<Ieee80211MacTrailer>());
    return packet;
}

static HeDlMuPackingPlanner::SelectedAllocation makePlannerSelection(const MacAddress& sta, int ruIndex, Packet *packet, uint16_t aid, bool multiTid = false)
{
    HeDlMuPackingPlanner::SelectedAllocation selected;
    selected.allocation = makeAllocation(sta, ruIndex, 242);
    selected.packet = packet;
    selected.dataHeader = dynamicPtrCast<const Ieee80211DataHeader>(packet->peekAtFront<Ieee80211MacHeader>());
    selected.associationId = aid;
    selected.multiTidAggregation = multiTid;
    return selected;
}

static int countTid(const std::vector<Packet *>& packets, Tid tid)
{
    int count = 0;
    for (auto packet : packets) {
        auto header = dynamicPtrCast<const Ieee80211DataHeader>(packet->peekAtFront<Ieee80211MacHeader>());
        if (header != nullptr && header->getTid() == tid)
            count++;
    }
    return count;
}

%activity:
auto callback = check_and_cast<MockDlMuCallback *>(getParentModule()->getSubmodule("mockHcf"));
auto pendingQueue = check_and_cast<queueing::IPacketQueue *>(getParentModule()->getSubmodule("pendingQueue"));
auto modeSet = const_cast<Ieee80211ModeSet *>(Ieee80211ModeSet::getModeSet("ax"));
ASSERT(modeSet != nullptr);

MacAddress sta1("02:00:00:00:20:01");
MacAddress sta2("02:00:00:00:20:02");
MacAddress sta3("02:00:00:00:20:03");
Tid tid = 3;

auto makePlannerParameters = [&] (const std::vector<HeDlMuPackingPlanner::SelectedAllocation>& selections,
        const std::set<std::pair<MacAddress, Tid>>& inactiveAgreements = {},
        const std::map<std::pair<MacAddress, Tid>, int>& slotLimits = {}) {
    HeDlMuPackingPlanner::Parameters parameters;
    parameters.selectedAllocations = selections;
    parameters.pendingQueue = pendingQueue;
    parameters.scheduleContext = makeScheduleContext({sta1, sta2, sta3}, SimTime(2, SIMTIME_MS));
    parameters.maxAmpduMpduCount = 8;
    parameters.maxHeMuPsduLength = 6500631;
    parameters.packingDurationLimit = SimTime(2, SIMTIME_MS);
    parameters.ppduDurationLimit = SimTime(2, SIMTIME_MS);
    parameters.hasActiveBlockAckAgreement = [inactiveAgreements] (const MacAddress& receiver, Tid tid) {
        return inactiveAgreements.find({receiver, tid}) == inactiveAgreements.end();
    };
    parameters.getAvailableBlockAckSlots = [slotLimits] (const MacAddress& receiver, Tid tid) {
        auto it = slotLimits.find({receiver, tid});
        return it == slotLimits.end() ? 64 : it->second;
    };
    parameters.warnIneligible = [] (Packet *, const MacAddress&, Tid, int, const char *) {};
    return parameters;
};

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("planner-pack-sta1-0", sta1, tid, 0, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-pack-sta1-1", sta1, tid, 1, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-pack-sta2-0", sta2, tid, 0, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-pack-sta2-1", sta2, tid, 1, 200));
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 1),
            makePlannerSelection(sta2, 1, pendingQueue->getPacket(2), 2)});
    auto plan = planner.plan(parameters);
    requireTrue(plan.valid, "planner should produce a valid multi-user packing plan");
    requireTrue(plan.allocations.size() == 2, "planner should keep both scheduled users");
    requireTrue(plan.allocations[0].packets.size() == 2, "planner should pack both STA1 MPDUs");
    requireTrue(plan.allocations[1].packets.size() == 2, "planner should pack both STA2 MPDUs");
    requireTrue(pendingQueue->getNumPackets() == 4, "planner must not mutate the source queue");
    EV << "Planner produced deterministic multi-user packing without queue mutation.\n";
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("planner-ba-sta1", sta1, tid, 10, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-ba-sta2", sta2, tid, 10, 200));
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 11),
            makePlannerSelection(sta2, 1, pendingQueue->getPacket(1), 12)},
            {}, {{{sta2, tid}, 0}});
    auto plan = planner.plan(parameters);
    requireTrue(!plan.valid, "planner should reject when BA-window exhaustion leaves one user");
    requireTrue(plan.rejectedFinalValidation == 1, "planner should count the exhausted BA-window rejection");
    requireTrue(pendingQueue->getNumPackets() == 2, "BA-window planning failure must not dequeue packets");
    EV << "Planner rejected BA-window exhaustion before queue mutation.\n";
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("planner-single-sta1", sta1, tid, 20, 200));
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 21)});
    auto plan = planner.plan(parameters);
    requireTrue(!plan.valid, "planner should reject a single surviving user");
    requireTrue(plan.failureReason.find("fewer than two") != std::string::npos, "planner should explain single-survivor rejection");
    requireTrue(pendingQueue->getNumPackets() == 1, "single-survivor planning failure must not dequeue packets");
    EV << "Planner rejected fewer than two surviving users.\n";
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("planner-multitid-sta1-t3", sta1, tid, 30, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-multitid-sta1-t4", sta1, 4, 31, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-multitid-sta2", sta2, tid, 30, 200));
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 31, true),
            makePlannerSelection(sta2, 1, pendingQueue->getPacket(2), 32)});
    auto plan = planner.plan(parameters);
    requireTrue(plan.valid, "planner should allow negotiated multi-TID packing");
    requireTrue(plan.allocations[0].packets.size() == 2, "planner should pack both eligible STA1 TIDs");
    requireTrue(countTid(plan.allocations[0].packets, tid) == 1, "planner should include STA1 TID 3");
    requireTrue(countTid(plan.allocations[0].packets, 4) == 1, "planner should include STA1 TID 4");
    EV << "Planner honored multi-TID aggregation eligibility.\n";
}

{
    clearQueue(pendingQueue);
    for (int i = 0; i < 4; i++) {
        pendingQueue->enqueuePacket(makeDataPacket(("planner-trim-sta1-" + std::to_string(i)).c_str(), sta1, tid, i, 200));
        pendingQueue->enqueuePacket(makeDataPacket(("planner-trim-sta2-" + std::to_string(i)).c_str(), sta2, tid, i, 200));
        pendingQueue->enqueuePacket(makeDataPacket(("planner-trim-sta3-" + std::to_string(i)).c_str(), sta3, tid, i, 200));
    }
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 41),
            makePlannerSelection(sta2, 1, pendingQueue->getPacket(1), 42),
            makePlannerSelection(sta3, 2, pendingQueue->getPacket(2), 43)});
    parameters.ppduDurationLimit = SimTime(900, SIMTIME_US);
    auto plan = planner.plan(parameters);
    requireTrue(plan.valid, "planner should trim to a valid PPDU/TXOP duration");
    int packedPackets = 0;
    for (const auto& allocation : plan.allocations)
        packedPackets += allocation.packets.size();
    requireTrue(plan.allocations.size() >= 2, "duration trimming should preserve MU operation");
    requireTrue(packedPackets < 12, "duration trimming should reduce the packed MPDU set");
    requireTrue(plan.durationTrimIterations > 0, "duration trimming should report trim iterations");
    EV << "Planner trimmed packed MPDUs to fit PPDU/TXOP duration.\n";
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("planner-dup-sta1", sta1, tid, 50, 200));
    pendingQueue->enqueuePacket(makeDataPacket("planner-dup-sta2", sta2, tid, 50, 200));
    HeDlMuPackingPlanner planner;
    auto parameters = makePlannerParameters({
            makePlannerSelection(sta1, 0, pendingQueue->getPacket(0), 51),
            makePlannerSelection(sta2, 1, pendingQueue->getPacket(1), 51)});
    auto plan = planner.plan(parameters);
    requireTrue(!plan.valid, "planner should reject duplicate association IDs");
    requireTrue(plan.rejectedFinalValidation == 2, "planner should reject both duplicate-AID allocations");
    requireTrue(pendingQueue->getNumPackets() == 2, "duplicate-AID planning failure must not dequeue packets");
    EV << "Planner rejected duplicate association IDs deterministically.\n";
}

{
    clearQueue(pendingQueue);
    for (int i = 0; i < 3; i++)
        pendingQueue->enqueuePacket(makeDataPacket(("pack-sta1-" + std::to_string(i)).c_str(), sta1, tid, i, 200));
    for (int i = 0; i < 2; i++)
        pendingQueue->enqueuePacket(makeDataPacket(("pack-sta2-" + std::to_string(i)).c_str(), sta2, tid, i, 200));
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 242), makeAllocation(sta2, 1, 242)});
    MockDlMuAckHandler ackHandler;
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid);
    baHandler.addAgreement(sta2, tid);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2}), modeSet, pendingQueue, &ackHandler, callback, 8);
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step != nullptr, "per-user packing should build a transmit step");
    requireTrue(step->getType() == IFrameSequenceStep::Type::TRANSMIT, "per-user packing should transmit the container");
    requireTrue(fs.getActiveAllocations().size() == 2, "per-user packing should keep two active allocations");
    requireTrue(fs.getActiveAllocations()[0].packets.size() == 3, "STA1 should pack three MPDUs");
    requireTrue(fs.getActiveAllocations()[1].packets.size() == 2, "STA2 should pack two MPDUs");
    requireTrue(ackHandler.inProgressCount == 5, "all packed MPDUs should enter Block Ack tracking");
    EV << "Per-user packet packing admitted multiple MPDUs per scheduled STA.\n";
    delete step;
    delete fsContext;
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("window-sta1", sta1, tid, 10, 200));
    pendingQueue->enqueuePacket(makeDataPacket("window-sta2", sta2, tid, 10, 200));
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 242), makeAllocation(sta2, 1, 242)});
    MockDlMuAckHandler ackHandler;
    for (int i = 0; i < 4; i++)
        ackHandler.occupied[{sta2, tid}].insert(i);
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid, 4);
    baHandler.addAgreement(sta2, tid, 4);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2}), modeSet, pendingQueue, &ackHandler, callback);
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step == nullptr, "BA-window exhaustion should abort MU container build");
    requireTrue(fs.getActiveAllocations().empty(), "BA-window exhaustion should leave no active allocations");
    requireTrue(pendingQueue->getNumPackets() == 2, "BA-window exhaustion should not dequeue packets");
    EV << "BA-window exhaustion rejected a user before queue mutation and fell back.\n";
    delete fsContext;
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("fallback-sta1", sta1, tid, 20, 200));
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 242), makeAllocation(sta2, 1, 242)});
    MockDlMuAckHandler ackHandler;
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid);
    baHandler.addAgreement(sta2, tid);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2}), modeSet, pendingQueue, &ackHandler, callback);
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step == nullptr, "single surviving user should abort MU container build");
    requireTrue(pendingQueue->getNumPackets() == 1, "single surviving user should not dequeue packets");
    EV << "Fewer than two surviving users aborted HE MU assembly without dequeueing.\n";
    delete fsContext;
}

{
    clearQueue(pendingQueue);
    for (int i = 0; i < 4; i++) {
        pendingQueue->enqueuePacket(makeDataPacket(("trim-sta1-" + std::to_string(i)).c_str(), sta1, tid, i, 200));
        pendingQueue->enqueuePacket(makeDataPacket(("trim-sta2-" + std::to_string(i)).c_str(), sta2, tid, i, 200));
        pendingQueue->enqueuePacket(makeDataPacket(("trim-sta3-" + std::to_string(i)).c_str(), sta3, tid, i, 200));
    }
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 242), makeAllocation(sta2, 1, 242), makeAllocation(sta3, 2, 242)});
    MockDlMuAckHandler ackHandler;
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid);
    baHandler.addAgreement(sta2, tid);
    baHandler.addAgreement(sta3, tid);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2, sta3}, SimTime(1800, SIMTIME_US)),
            modeSet, pendingQueue, &ackHandler, callback, 8, 6500631, SimTime(900, SIMTIME_US));
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step != nullptr, "TXOP trimming should still build a transmit step");
    requireTrue(step->getType() == IFrameSequenceStep::Type::TRANSMIT, "TXOP trimming should transmit the container");
    int packedPackets = 0;
    for (const auto& allocation : fs.getActiveAllocations())
        packedPackets += allocation.packets.size();
    requireTrue(fs.getActiveAllocations().size() >= 2, "TXOP trimming should preserve at least two users");
    requireTrue(packedPackets < 12, "TXOP trimming should reduce the packed MPDU set");
    EV << "TXOP/PPDU duration trimming reduced the packed MPDU set while preserving MU operation.\n";
    delete step;
    delete fsContext;
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("voice-txop-sta1", sta1, tid, 0, 100));
    pendingQueue->enqueuePacket(makeDataPacket("voice-txop-sta2", sta2, tid, 0, 100));
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 106), makeAllocation(sta2, 1, 106)});
    MockDlMuAckHandler ackHandler;
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid);
    baHandler.addAgreement(sta2, tid);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2}, SimTime(1504, SIMTIME_US)),
            modeSet, pendingQueue, &ackHandler, callback);
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step != nullptr, "106-tone MU-BAR responses should leave payload time in an AC_VO TXOP");
    requireTrue(fs.getActiveAllocations().size() == 2, "voice TXOP should preserve both 106-tone users");
    EV << "MU-BAR response timing used scheduled RU widths within the voice TXOP.\n";
    delete step;
    delete fsContext;
}

{
    clearQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("narrow-txop-sta1", sta1, tid, 0, 100));
    pendingQueue->enqueuePacket(makeDataPacket("narrow-txop-sta2", sta2, tid, 0, 100));
    MockDlMuScheduler scheduler({makeAllocation(sta1, 0, 26), makeAllocation(sta2, 1, 26)});
    MockDlMuAckHandler ackHandler;
    MockDlMuInProgressFrames inProgress;
    MockDlMuOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid);
    baHandler.addAgreement(sta2, tid);
    auto qosContext = new QoSContext(nullptr, nullptr, &baHandler, nullptr);
    auto fsContext = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), modeSet, &inProgress, nullptr, nullptr, nullptr, qosContext);
    HeDlMuTxOpFs fs(&scheduler, makeScheduleContext({sta1, sta2}, SimTime(1504, SIMTIME_US)),
            modeSet, pendingQueue, &ackHandler, callback);
    fs.startSequence(fsContext, 0);
    auto step = fs.prepareStep(fsContext);
    requireTrue(step == nullptr, "26-tone MU-BAR responses should not overrun an AC_VO TXOP");
    requireTrue(pendingQueue->getNumPackets() == 2, "response-phase TXOP rejection must not dequeue packets");
    EV << "MU-BAR response timing rejected a genuinely too-narrow voice TXOP.\n";
    delete fsContext;
}

clearQueue(pendingQueue);
EV << ".\n";

