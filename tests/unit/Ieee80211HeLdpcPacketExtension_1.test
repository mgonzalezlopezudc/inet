%description:
Test HE LDPC accounting, packet-extension timing, extended HE header controls,
and puncturing-aware RU allocation.

%includes:
#include "inet/common/packet/Packet.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HePhyCalculator.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"

%global:

using namespace inet;
using namespace inet::physicallayer;

%activity:

auto ru = makeHeRu(Hz(5.18e9), 996, 1, 242, 0);
auto bcc = computeHeUserPhyParameters(B(1500), ru, 5, 1, false, HE_GI_1_6_US, HE_CODING_BCC);
auto ldpc = computeHeUserPhyParameters(B(1500), ru, 5, 1, false, HE_GI_1_6_US, HE_CODING_LDPC);
ASSERT(bcc.tailBits > 0);
ASSERT(ldpc.tailBits == 0);
ASSERT(ldpc.ldpcCodewordLength > 0);
ASSERT(ldpc.ldpcCodewordCount > 0);
EV << "HE LDPC tail omission and codeword accounting passed.\n";

Ieee80211HeUserPhyParameters request;
request.ru = ru;
request.mcs = 5;
request.psduLength = B(1500);
auto noPe = computeHePpduParameters({request}, Hz(80e6), HE_MU_DOWNLINK, HE_GI_1_6_US,
        HE_LTF_4X, 0);
auto pe = computeHePpduParameters({request}, Hz(80e6), HE_MU_DOWNLINK, HE_GI_1_6_US,
        HE_LTF_4X, 8);
ASSERT(noPe && pe);
ASSERT(pe.parameters.duration - noPe.parameters.duration == SimTime(8, SIMTIME_US));
EV << "HE packet extension timing passed.\n";

auto header = makeShared<Ieee80211HeMuPhyHeader>();
header->setCoding(HE_CODING_LDPC);
header->setPacketExtensionDurationUs(8);
header->setPuncturedSubchannelMask(0x4);
Ieee80211HeMuUserInfo user;
user.ruIndex = 1;
user.ruToneSize = 242;
user.staId = 1;
header->appendUsers(user);
header->setChunkLength(b(120 + 137));
auto packet = new Packet("extended-he-header", header);
auto bytes = packet->peekDataAsBytes();
auto received = new Packet("extended-he-header-rx", bytes);
auto decoded = received->popAtFront<Ieee80211HeMuPhyHeader>();
ASSERT(decoded->getCoding() == HE_CODING_LDPC);
ASSERT(decoded->getPacketExtensionDurationUs() == 8);
ASSERT(decoded->getPuncturedSubchannelMask() == 0x4);
delete packet;
delete received;
EV << "Extended HE header round trip passed.\n";

std::vector<Ieee80211HeRu> allocations;
ASSERT(allocateHeRus(Hz(5.18e9), Hz(80e6), {242, 242}, allocations,
        {false, true, false, false}));
for (const auto& allocation : allocations)
    ASSERT(!(allocation.toneOffset < 498 && allocation.toneOffset + allocation.toneSize > 249));
EV << "Punctured RU allocation avoided the disabled subchannel.\n";
EV << ".\n";

%contains: stdout
HE LDPC tail omission and codeword accounting passed.
HE packet extension timing passed.
Extended HE header round trip passed.
Punctured RU allocation avoided the disabled subchannel.
.
