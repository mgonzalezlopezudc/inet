%description:
Test that the packet printer can display IEEE 802.11 control frames with
undissected body bytes, such as HE Trigger frames.

%includes:
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/packet/Packet.h"
#include "inet/common/packet/chunk/ByteCountChunk.h"
#include "inet/common/packet/printer/PacketPrinter.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"

using namespace inet;
using namespace inet::ieee80211;

%activity:

Packet packet("he-trigger-with-body");
auto header = makeShared<Ieee80211MacHeader>();
header->setType(ST_TRIGGER);
header->setReceiverAddress(MacAddress("0A-AA-00-00-00-01"));
packet.insertAtBack(header);
packet.insertAtBack(makeShared<ByteCountChunk>(B(14)));
packet.insertAtBack(makeShared<Ieee80211MacTrailer>());
packet.addTag<PacketProtocolTag>()->setProtocol(&Protocol::ieee80211Mac);

PacketPrinter printer;
auto text = printer.printPacketToString(&packet);
ASSERT(text.find("Condition") == std::string::npos);
ASSERT(text.find("Trigger") != std::string::npos);
std::cout << text;
std::cout << "Packet printer accepted trigger body.\n";

Packet qosNullPacket("he-qos-null");
auto qosNullHeader = makeShared<Ieee80211DataHeader>();
qosNullHeader->setType(ST_QOS_NULL);
qosNullHeader->setReceiverAddress(MacAddress("0A-AA-00-00-00-01"));
qosNullHeader->setTransmitterAddress(MacAddress("0A-AA-00-00-00-02"));
qosNullHeader->setAddress3(MacAddress("0A-AA-00-00-00-01"));
qosNullHeader->setToDS(true);
qosNullHeader->setTid(0);
qosNullHeader->setAckPolicy(BLOCK_ACK);
qosNullHeader->setOrder(true);
qosNullHeader->setBufferStatusPresent(true);
qosNullHeader->setChunkLength(B(30));
qosNullPacket.insertAtBack(qosNullHeader);
qosNullPacket.insertAtBack(makeShared<Ieee80211MacTrailer>());
qosNullPacket.addTag<PacketProtocolTag>()->setProtocol(&Protocol::ieee80211Mac);

text = printer.printPacketToString(&qosNullPacket);
ASSERT(text.find("Condition") == std::string::npos);
ASSERT(text.find("QoS Null") != std::string::npos);
std::cout << text;
std::cout << "Packet printer accepted empty QoS Null payload.\n";
std::cout << "Packet printer accepted 802.11 display frames.\n";

%contains: stdout
Packet printer accepted 802.11 display frames.
