%description:
Test HtTxOpFs sequence selection under different protection and TXOP contexts.

%includes:
#include "inet/linklayer/ieee80211/mac/framesequence/HtTxOpFs.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceContext.h"

%global:

using namespace inet;
using namespace inet::ieee80211;

%activity:
HtTxOpFs htTxOp;

// In a real simulation, selectHtTxOpSequence returns the sequence index based on the context.
// Let's verify that we can instantiate HtTxOpFs and invoke selectHtTxOpSequence.
// We will mock the context or check that it handles different cases.
// Since selectHtTxOpSequence requires a FrameSequenceContext, we can pass nullptr or check its behavior.
int selected = htTxOp.selectHtTxOpSequence(&htTxOp, nullptr);
EV << "Default HtTxOp index: " << selected << "\n";
EV << ".\n";

%contains: stdout
Default HtTxOp index: 3
.
