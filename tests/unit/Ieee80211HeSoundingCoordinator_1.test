%description:
Test HE Sounding Coordinator STA-side state machine.

%includes:
#include "inet/linklayer/ieee80211/mac/coordinationfunction/HeSoundingCoordinator.h"
#include "inet/linklayer/ieee80211/mib/Ieee80211Mib.h"
#include "inet/linklayer/ieee80211/mac/contract/ITx.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Mac.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/linklayer/ieee80211/mgmt/Ieee80211MgmtFrame_m.h"

%file: TestNetwork.ned
import inet.linklayer.ieee80211.mac.coordinationfunction.HeSoundingCoordinator;
import inet.linklayer.ieee80211.mib.Ieee80211Mib;

module MockMac
{
    submodules:
        mib: Ieee80211Mib;
}

module MockNic
{
    submodules:
        mac: MockMac;
        soundingCoordinator: HeSoundingCoordinator;
}

network TestNetwork
{
    submodules:
        test: Test;
        nic: MockNic;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;

class MockTransmitter : public ITx
{
  public:
    Packet *lastSent = nullptr;

    virtual bool isBusy() const override { return false; }
    virtual void transmitFrame(Packet *packet, const Ptr<const Ieee80211MacHeader>& header, ICallback *callback) override {}
    virtual void transmitFrame(Packet *packet, const Ptr<const Ieee80211MacHeader>& header, simtime_t ifs, ICallback *callback) override {
        lastSent = packet->dup();
        EV << "Mock Transmitter: sent frame '" << packet->getName() << "'\n";
    }
    virtual void radioTransmissionFinished() override {}
};

class MockMacReal : public Ieee80211Mac {
  public:
    Ieee80211Mib *mibRef = nullptr;
    virtual Ieee80211Mib *getMib() const override { return mibRef; }
    virtual const MacAddress& getAddress() const override {
        static MacAddress myAddr("00:11:22:33:44:55");
        return myAddr;
    }
};

%activity:
auto nic = getParentModule()->getSubmodule("nic");
auto soundingCoordinator = check_and_cast<HeSoundingCoordinator *>(nic->getSubmodule("soundingCoordinator"));
auto macMib = check_and_cast<Ieee80211Mib *>(nic->getSubmodule("mac")->getSubmodule("mib"));

// Set association ID for our STA to 5
macMib->bssStationData.associationId = 5;

MockMacReal mockMac;
mockMac.mibRef = macMib;

MockTransmitter mockTx;
    auto modeSet = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
HeMuMimoCsiManager csiManager;

// 1. Send NDP Announcement targeting AID 5
{
    auto ndpa = makeShared<Ieee80211HeNdpAnnouncement>();
    ndpa->setDialogToken(12);
    ndpa->setStationsArraySize(1);
    Ieee80211HeNdpStaInfo info;
    info.aid = 5;
    info.nc = 2;
    ndpa->setStations(0, info);
    ndpa->setChunkLength(B(20));

    auto header = makeShared<Ieee80211MgmtHeader>();
    header->setType(ST_ACTION);
    header->setReceiverAddress(MacAddress("00:11:22:33:44:55"));
    header->setTransmitterAddress(MacAddress("66:77:88:99:AA:BB"));

    auto pkt = new Packet("NDPA", header);
    pkt->insertAtBack(ndpa);

    bool res = soundingCoordinator->processSoundingFrame(pkt, header, &mockMac, modeSet, csiManager, &mockTx, nullptr);
    EV << "NDPA processed: " << (res ? "yes" : "no") << "\n";
}

// 2. Receive NDP (Legacy Preamble)
{
    soundingCoordinator->processLegacyPreamble(nullptr);
    EV << "NDP processed\n";
}

// 3. Receive Beamforming Report Poll (Trigger Frame type 2)
{
    auto trigger = makeShared<Ieee80211TriggerFrame>();
    trigger->setTriggerType(2); // Beamforming Report Poll
    trigger->setUsersArraySize(1);
    Ieee80211HeTriggerUserInfo user;
    user.aid = 5;
    user.ruIndex = 1;
    user.ruToneSize = 242;
    trigger->setUsers(0, user);
    trigger->setTransmitterAddress(MacAddress("66:77:88:99:AA:BB"));

    auto pkt = new Packet("BRP", trigger);
    bool res = soundingCoordinator->processSoundingFrame(pkt, trigger, &mockMac, modeSet, csiManager, &mockTx, nullptr);
    EV << "BRP processed: " << (res ? "yes" : "no") << "\n";

    if (mockTx.lastSent != nullptr) {
        EV << "Transmitted action frame: " << mockTx.lastSent->getName() << "\n";
        delete mockTx.lastSent;
    }
}

EV << ".\n";

%contains: stdout
NDPA processed: yes
NDP processed
Mock Transmitter: sent frame 'HE-Feedback'
BRP processed: yes
Transmitted action frame: HE-Feedback
.
