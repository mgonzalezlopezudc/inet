%description:
Test strict active ADDBA validation before packets enter an HE MU OFDMA container.

%includes:
#include <string>
#include "inet/linklayer/common/MacAddress.h"
#include "inet/linklayer/ieee80211/mac/blockack/OriginatorBlockAckAgreement.h"
#include "inet/linklayer/ieee80211/mac/blockack/OriginatorBlockAckAgreementHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IAckHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IFrameSequence.h"
#include "inet/linklayer/ieee80211/mac/contract/IOriginatorBlockAckAgreementHandler.h"
#include "inet/linklayer/ieee80211/mac/contract/IOriginatorBlockAckAgreementPolicy.h"
#include "inet/linklayer/ieee80211/mac/contract/IProcedureCallback.h"
#include "inet/linklayer/ieee80211/mac/contract/IQosRateSelection.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceContext.h"
#include "inet/linklayer/ieee80211/mac/framesequence/FrameSequenceStep.h"
#include "inet/linklayer/ieee80211/mac/framesequence/HeDlMuTxOpFs.h"
#include "inet/linklayer/ieee80211/mac/queue/InProgressFrames.h"
#include "inet/common/packet/chunk/ByteCountChunk.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/queueing/contract/IPacketQueue.h"

%file: TestNetwork.ned
import inet.queueing.queue.PacketQueue;

simple MockRateSelection
{
    @class(MockRateSelection);
}

module MockCallback
{
    parameters:
        @class(MockCallback);
    submodules:
        rateSelection: MockRateSelection;
}

network TestNetwork
{
    submodules:
        test: Test;
        mockHcf: MockCallback;
        pendingQueue: PacketQueue;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;

class MockRateSelection : public cSimpleModule, public IQosRateSelection
{
  public:
    virtual const physicallayer::IIeee80211Mode *computeResponseCtsFrameMode(Packet *packet, const Ptr<const Ieee80211RtsFrame>& rtsFrame) override { return nullptr; }
    virtual const physicallayer::IIeee80211Mode *computeResponseAckFrameMode(Packet *packet, const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
    virtual const physicallayer::IIeee80211Mode *computeResponseBlockAckFrameMode(Packet *packet, const Ptr<const Ieee80211BlockAckReq>& blockAckReq) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
    virtual const physicallayer::IIeee80211Mode *computeMode(Packet *packet, const Ptr<const Ieee80211MacHeader>& header, TxopProcedure *txopProcedure) override {
        auto ms = const_cast<physicallayer::Ieee80211ModeSet *>(physicallayer::Ieee80211ModeSet::getModeSet("ax"));
        return ms->getMode(0);
    }
};

Define_Module(MockRateSelection);

class MockAckHandler : public IAckHandler
{
  public:
    int inProgressCount = 0;
    virtual bool isEligibleToTransmit(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return true; }
    virtual bool isOutstandingFrame(const Ptr<const Ieee80211DataOrMgmtHeader>& header) override { return false; }
    virtual void frameGotInProgress(const Ptr<const Ieee80211DataOrMgmtHeader>& dataOrMgmtHeader) override { inProgressCount++; }
};

class MockScheduler : public IIeee80211HeDlScheduler
{
  public:
    std::vector<MacAddress> scheduledStations;
    simtime_t estimatedDuration = SIMTIME_ZERO;

    MockScheduler(const std::vector<MacAddress>& scheduledStations, simtime_t estimatedDuration = SIMTIME_ZERO) :
        scheduledStations(scheduledStations), estimatedDuration(estimatedDuration) {}

    virtual std::vector<RuAllocation> schedule(const std::vector<MacAddress>& candidateStations, Hz centerFrequency, Hz bandwidth) override {
        std::vector<RuAllocation> allocs;
        for (size_t i = 0; i < scheduledStations.size(); i++) {
            RuAllocation alloc;
            alloc.staAddress = scheduledStations[i];
            alloc.ru.index = i;
            alloc.ru.toneSize = 26;
            alloc.mcs = 0;
            alloc.estimatedDuration = estimatedDuration;
            allocs.push_back(alloc);
        }
        return allocs;
    }
};

class MockInProgressFrames : public InProgressFrames
{
  public:
    virtual ~MockInProgressFrames() {
        inProgressFrames.clear();
    }
};

class MockOriginatorBlockAckAgreementHandler : public IOriginatorBlockAckAgreementHandler
{
  public:
    std::vector<OriginatorBlockAckAgreement *> agreements;

    virtual ~MockOriginatorBlockAckAgreementHandler() {
        for (auto agreement : agreements)
            delete agreement;
    }

    OriginatorBlockAckAgreement *addAgreement(const MacAddress& receiver, Tid tid, bool active, int bufferSize = 64) {
        auto agreement = new OriginatorBlockAckAgreement(receiver, tid, SequenceNumberCyclic(0), bufferSize, false, false);
        agreement->setIsAddbaResponseReceived(active);
        agreements.push_back(agreement);
        return agreement;
    }

    virtual void processReceivedBlockAck(const Ptr<const Ieee80211BlockAck>& blockAck, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processTransmittedAddbaReq(const Ptr<const Ieee80211AddbaRequest>& addbaReq) override {}
    virtual void processTransmittedDataFrame(Packet *packet, const Ptr<const Ieee80211DataHeader>& dataHeader, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IProcedureCallback *callback) override {}
    virtual void processReceivedAddbaResp(const Ptr<const Ieee80211AddbaResponse>& addbaResp, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy, IBlockAckAgreementHandlerCallback *callback) override {}
    virtual void processReceivedDelba(const Ptr<const Ieee80211Delba>& delba, IOriginatorBlockAckAgreementPolicy *blockAckAgreementPolicy) override {}
    virtual void processTransmittedDelba(const Ptr<const Ieee80211Delba>& delba) override {}
    virtual void blockAckAgreementExpired(IProcedureCallback *procedureCallback, IBlockAckAgreementHandlerCallback *agreementHandlerCallback) override {}

    virtual OriginatorBlockAckAgreement *getAgreement(MacAddress receiverAddr, Tid tid) override {
        for (auto agreement : agreements) {
            if (agreement->getReceiverAddr() == receiverAddr && agreement->getTid() == tid)
                return agreement;
        }
        return nullptr;
    }

    bool hasReceivedAddbaResponse(MacAddress receiverAddr, Tid tid) {
        auto agreement = getAgreement(receiverAddr, tid);
        return agreement != nullptr && agreement->getIsAddbaResponseReceived();
    }
};

class MockOriginatorBlockAckAgreementPolicy : public IOriginatorBlockAckAgreementPolicy
{
    public:
        simtime_t addbaFailureTimeout = SimTime(1, SIMTIME_S);

        virtual bool isAddbaReqNeeded(Packet *packet, const Ptr<const Ieee80211DataHeader>& header) override { return true; }
        virtual bool isAddbaReqAccepted(const Ptr<const Ieee80211AddbaResponse>& addbaResp, OriginatorBlockAckAgreement *agreement) override { return true; }
        virtual bool isDelbaAccepted(const Ptr<const Ieee80211Delba>& delba) override { return true; }
        virtual bool isMsduSupported() const override { return true; }
        virtual simtime_t computeAddbaFailureTimeout() const override { return addbaFailureTimeout; }
        virtual simtime_t getBlockAckTimeoutValue() const override { return SimTime::ZERO; }
        virtual bool isDelayedAckPolicySupported() const override { return false; }
        virtual int getMaximumAllowedBufferSize() const override { return 64; }
};

class MockProcedureCallback : public IProcedureCallback
{
    public:
        OriginatorBlockAckAgreementHandler *handler = nullptr;
        int addbaReqCount = 0;

        explicit MockProcedureCallback(OriginatorBlockAckAgreementHandler *handler) : handler(handler) {}

        virtual void transmitControlResponseFrame(Packet *responsePacket, const Ptr<const Ieee80211MacHeader>& responseHeader, Packet *receivedPacket, const Ptr<const Ieee80211MacHeader>& receivedHeader) override {}

        virtual void processMgmtFrame(Packet *mgmtPacket, const Ptr<const Ieee80211MgmtHeader>& mgmtHeader) override {
                if (auto addbaReq = dynamicPtrCast<const Ieee80211AddbaRequest>(mgmtHeader)) {
                        addbaReqCount++;
                        if (handler != nullptr)
                                handler->processTransmittedAddbaReq(addbaReq);
                }
                delete mgmtPacket;
        }
};

class MockCallback : public cSimpleModule, public IFrameSequenceHandler::ICallback
{
  public:
    virtual void transmitFrame(Packet *packet, simtime_t ifs) override {}
    virtual void scheduleStartRxTimer(simtime_t timeout) override {}
    virtual void originatorProcessTransmittedFrame(Packet *packet) override {}
    virtual void originatorProcessReceivedFrame(Packet *receivedPacket, Packet *lastTransmittedPacket) override {}
    virtual void originatorProcessFailedFrame(Packet *failedPacket) override {}
    virtual void originatorProcessRtsProtectionFailed(Packet *packet) override {}
    virtual void frameSequenceFinished() override {}
};

Define_Module(MockCallback);

static void clearPendingQueue(queueing::IPacketQueue *pendingQueue)
{
    while (pendingQueue->getNumPackets() > 0) {
        auto packet = pendingQueue->getPacket(0);
        pendingQueue->removePacket(packet);
        delete packet;
    }
}

static Packet *makeDataPacket(const char *name, const MacAddress& receiver, Tid tid, bool qos, int payloadBytes = 0)
{
    Packet *packet = new Packet(name);
    auto header = makeShared<Ieee80211DataHeader>();
    header->setReceiverAddress(receiver);
    header->setType(qos ? ST_DATA_WITH_QOS : ST_DATA);
    header->setTid(tid);
    header->setAckPolicy(BLOCK_ACK);
    header->setSequenceNumber(SequenceNumberCyclic(tid));
    packet->insertAtFront(header);
    if (payloadBytes > 0)
        packet->insertAtBack(makeShared<ByteCountChunk>(B(payloadBytes)));
    return packet;
}

static bool isPacketQueued(queueing::IPacketQueue *pendingQueue, const char *name)
{
    for (int i = 0; i < pendingQueue->getNumPackets(); i++) {
        if (!strcmp(pendingQueue->getPacket(i)->getName(), name))
            return true;
    }
    return false;
}

static void requireCondition(bool condition, const char *message)
{
    if (!condition)
        throw cRuntimeError("%s", message);
}

struct FirstTransmitStepResult {
    Packet *container = nullptr;
    int ackHandlerInProgressCount = 0;
    int inProgressLength = 0;
    bool allInProgressUseBlockAck = true;
    bool allInProgressHaveDuration = true;
};

static FirstTransmitStepResult runFirstTransmitStep(queueing::IPacketQueue *pendingQueue, MockCallback *callback,
        const std::vector<MacAddress>& scheduledStations, IOriginatorBlockAckAgreementHandler *baHandler,
        int maxAmpduMpduCount = 16, int maxHeMuPsduLength = 6500631,
        simtime_t maxHeMuPpduDuration = SimTime(5.484, SIMTIME_MS),
        simtime_t alignedDuration = SIMTIME_ZERO, simtime_t txopPayloadBudget = SIMTIME_ZERO)
{
    auto modeSet = physicallayer::Ieee80211ModeSet::getModeSet("ax");
    auto scheduler = new MockScheduler(scheduledStations, alignedDuration);
    auto ackHandler = new MockAckHandler();
    auto inProgress = new MockInProgressFrames();
    auto qosContext = new QoSContext(nullptr, nullptr, baHandler, nullptr);
    auto context = new FrameSequenceContext(MacAddress("AA:BB:CC:DD:EE:FF"), const_cast<physicallayer::Ieee80211ModeSet *>(modeSet), inProgress, nullptr, nullptr, nullptr, qosContext);
    IIeee80211HeDlScheduler::ScheduleContext scheduleContext;
    for (size_t i = 0; i < scheduledStations.size(); ++i) {
        IIeee80211HeDlScheduler::CandidateInfo candidate;
        candidate.staAddress = scheduledStations[i];
        candidate.anchor = i == 0;
        scheduleContext.candidates.push_back(candidate);
    }
    scheduleContext.anchorSta = scheduledStations.front();
    if (txopPayloadBudget > SIMTIME_ZERO) {
        auto rateSelection = check_and_cast<IQosRateSelection *>(callback->getSubmodule("rateSelection"));
        auto dummyReq = makeShared<Ieee80211BasicBlockAckReq>();
        auto responseMode = rateSelection->computeResponseBlockAckFrameMode(nullptr, dummyReq);
        simtime_t ackSequenceDuration = modeSet->getSifsTime() + responseMode->getDuration(LENGTH_BASIC_BLOCKACK);
        for (size_t i = 1; i < scheduledStations.size(); ++i)
            ackSequenceDuration += modeSet->getSifsTime() + responseMode->getDuration(B(38)) +
                    modeSet->getSifsTime() + responseMode->getDuration(LENGTH_BASIC_BLOCKACK);
        scheduleContext.txopLimit = ackSequenceDuration + txopPayloadBudget;
    }
    HeDlMuTxOpFs *fs = new HeDlMuTxOpFs(scheduler, scheduleContext,
            const_cast<physicallayer::Ieee80211ModeSet *>(modeSet), pendingQueue, ackHandler, callback,
            maxAmpduMpduCount, maxHeMuPsduLength, maxHeMuPpduDuration);

    fs->startSequence(context, 0);
    FirstTransmitStepResult result;
    auto preparedStep = fs->prepareStep(context);
    if (preparedStep != nullptr) {
        auto step0 = check_and_cast<ITransmitStep *>(preparedStep);
        result.container = step0->getFrameToTransmit()->dup();
        result.ackHandlerInProgressCount = ackHandler->inProgressCount;
        result.inProgressLength = inProgress->getLength();
        for (int i = 0; i < inProgress->getLength(); i++) {
            auto header = inProgress->getFrames(i)->peekAtFront<Ieee80211DataHeader>();
            result.allInProgressUseBlockAck = result.allInProgressUseBlockAck && header->getAckPolicy() == BLOCK_ACK;
            result.allInProgressHaveDuration = result.allInProgressHaveDuration && header->getDurationField() > SIMTIME_ZERO;
        }
        delete step0;
    }

    delete fs;
    delete context;
    delete inProgress;
    delete ackHandler;
    delete scheduler;

    return result;
}

static void expectMuAllocationCount(Packet *container, size_t expectedCount)
{
    auto packetCopy = container->dup();
    packetCopy->popAtFront<Ieee80211MacHeader>();
    size_t count = 0;
    while (packetCopy->getDataLength() > b(0)) {
        auto payloadHeader = dynamicPtrCast<const physicallayer::Ieee80211HeMuRuPayloadHeader>(packetCopy->peekAtFront());
        if (payloadHeader == nullptr)
            break;
        packetCopy->popAtFront<physicallayer::Ieee80211HeMuRuPayloadHeader>();
        packetCopy->popAtFront(payloadHeader->getMpduLength());
        count++;
    }
    delete packetCopy;
    if (count != expectedCount)
        throw cRuntimeError("Expected %zu HE MU RU payload sections, got %zu", expectedCount, count);
}

%activity:
auto mockHcf = check_and_cast<MockCallback *>(getParentModule()->getSubmodule("mockHcf"));
auto pendingQueue = check_and_cast<queueing::IPacketQueue *>(getParentModule()->getSubmodule("pendingQueue"));

MacAddress sta1("00:11:22:33:44:55");
MacAddress sta2("66:77:88:99:AA:BB");
MacAddress sta3("02:00:00:00:00:03");
MacAddress sta4("02:00:00:00:00:04");
Tid tid = 5;

// Test 1: active receiver/TID agreements produce a transmit step with two HE MU allocations.
{
    clearPendingQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("active-sta1", sta1, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("active-sta2", sta2, tid, true));

    MockOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid, true);
    baHandler.addAgreement(sta2, tid, true);
    requireCondition(baHandler.hasReceivedAddbaResponse(sta1, tid), "active fixture agreement was not marked active");

    auto result = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2}, &baHandler);
    expectMuAllocationCount(result.container, 2);
    requireCondition(pendingQueue->getNumPackets() == 0, "active ADDBA packets should be removed from the pending queue");
    requireCondition(result.ackHandlerInProgressCount == 2, "admitted packets must be reported to the ack handler");
    requireCondition(result.inProgressLength == 2, "admitted packets must be moved into InProgressFrames");
    requireCondition(result.allInProgressUseBlockAck, "admitted packets must be marked with BLOCK_ACK policy");
    requireCondition(result.allInProgressHaveDuration, "admitted packets must receive a nonzero duration field");
    EV << "Active ADDBA agreements admitted two QoS packets.\n";
    EV << "Admitted packets moved to InProgressFrames with BLOCK_ACK and duration fields.\n";
    delete result.container;
}

// Test 2: an existing but inactive agreement is not admitted; the packet stays pending.
{
    clearPendingQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta1", sta1, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta2", sta2, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("inactive-sta3", sta3, tid, true));

    MockOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid, true);
    baHandler.addAgreement(sta2, tid, true);
    baHandler.addAgreement(sta3, tid, false);

    auto result = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2, sta3}, &baHandler);
    expectMuAllocationCount(result.container, 2);
    requireCondition(pendingQueue->getNumPackets() == 1, "inactive ADDBA packet should remain pending");
    requireCondition(isPacketQueued(pendingQueue, "inactive-sta3"), "inactive ADDBA packet was removed from the pending queue");
    EV << "Inactive ADDBA agreement packet remained pending.\n";
    delete result.container;
}

// Test 3: missing agreement, null BA handler, non-QoS data, and wrong TID are ineligible.
{
    clearPendingQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta1", sta1, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta2", sta2, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("missing-agreement-sta3", sta3, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("wrong-tid-sta4", sta4, tid + 1, true));

    MockOriginatorBlockAckAgreementHandler baHandler;
    baHandler.addAgreement(sta1, tid, true);
    baHandler.addAgreement(sta2, tid, true);
    baHandler.addAgreement(sta4, tid, true);

    auto result = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2, sta3, sta4}, &baHandler);
    expectMuAllocationCount(result.container, 2);
    requireCondition(pendingQueue->getNumPackets() == 2, "missing agreement and wrong TID packets should remain pending");
    requireCondition(isPacketQueued(pendingQueue, "missing-agreement-sta3"), "missing agreement packet was removed from the pending queue");
    requireCondition(isPacketQueued(pendingQueue, "wrong-tid-sta4"), "wrong TID packet was removed from the pending queue");
    EV << "Missing agreement and wrong TID packets remained pending.\n";
    delete result.container;

    clearPendingQueue(pendingQueue);
    auto broadcast = MacAddress::BROADCAST_ADDRESS;
    auto multicast = MacAddress("01:00:5E:00:00:01");
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta1-with-mcast", sta1, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("valid-sta2-with-bcast", sta2, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("broadcast-qos", broadcast, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("multicast-qos", multicast, tid, true));

    MockOriginatorBlockAckAgreementHandler multicastBaHandler;
    multicastBaHandler.addAgreement(sta1, tid, true);
    multicastBaHandler.addAgreement(sta2, tid, true);

    auto multicastResult = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, broadcast, multicast, sta2, sta4}, &multicastBaHandler);
    expectMuAllocationCount(multicastResult.container, 2);
    requireCondition(pendingQueue->getNumPackets() == 2, "multicast/broadcast packets should remain pending");
    requireCondition(isPacketQueued(pendingQueue, "broadcast-qos"), "broadcast packet was removed from the pending queue");
    requireCondition(isPacketQueued(pendingQueue, "multicast-qos"), "multicast packet was removed from the pending queue");
    EV << "Multicast, broadcast, and no-queued-packet scheduler allocations were skipped without mutation.\n";
    delete multicastResult.container;

    clearPendingQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("non-qos-sta1", sta1, tid, false));
    pendingQueue->enqueuePacket(makeDataPacket("null-handler-sta2", sta2, tid, true));

    auto invalidResult = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2}, nullptr);
    bool abortedWithoutMutation = invalidResult.container == nullptr;
    delete invalidResult.container;
    EV << "Null handler/non-QoS preflight returned no MU step.\n";
    requireCondition(abortedWithoutMutation, "null BA handler and non-QoS preflight should abort before mutation");
    requireCondition(pendingQueue->getNumPackets() == 2, "null BA handler and non-QoS packets should remain pending");
    requireCondition(isPacketQueued(pendingQueue, "non-qos-sta1"), "non-QoS packet was removed from the pending queue");
    requireCondition(isPacketQueued(pendingQueue, "null-handler-sta2"), "null-handler packet was removed from the pending queue");
    EV << "Null BA handler and non-QoS packets remained pending.\n";

    clearPendingQueue(pendingQueue);
    pendingQueue->enqueuePacket(makeDataPacket("only-active-sta1", sta1, tid, true));
    pendingQueue->enqueuePacket(makeDataPacket("inactive-sta2-abort", sta2, tid, true));
    MockOriginatorBlockAckAgreementHandler oneActiveHandler;
    oneActiveHandler.addAgreement(sta1, tid, true);
    oneActiveHandler.addAgreement(sta2, tid, false);

    auto oneActiveResult = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2}, &oneActiveHandler);
    bool singleActiveAbortedWithoutMutation = oneActiveResult.container == nullptr;
    delete oneActiveResult.container;
    EV << "Single active allocation preflight returned no MU step.\n";
    requireCondition(singleActiveAbortedWithoutMutation, "fewer than two active allocations should abort before mutation");
    requireCondition(pendingQueue->getNumPackets() == 2, "single-active abort should not mutate pending queue");
    requireCondition(isPacketQueued(pendingQueue, "only-active-sta1"), "single active packet was removed during abort");
    requireCondition(isPacketQueued(pendingQueue, "inactive-sta2-abort"), "inactive packet was removed during abort");
    EV << "Fewer than two active allocations aborted before queue mutation.\n";
}

// Test 4: per-user A-MPDU packing obeys BA-window, PSDU-length, PPDU-duration,
// aligned-duration, and remaining-TXOP limits before mutating the queue.
{
    auto runPackingLimitCase = [&] (const char *prefix, int blockAckWindow, int maxPsduLength,
            simtime_t maxPpduDuration, simtime_t alignedDuration, simtime_t txopPayloadBudget) {
        clearPendingQueue(pendingQueue);
        for (int i = 0; i < 3; ++i) {
            pendingQueue->enqueuePacket(makeDataPacket((std::string(prefix) + "-sta1-" + std::to_string(i)).c_str(), sta1, tid, true, 10));
            pendingQueue->enqueuePacket(makeDataPacket((std::string(prefix) + "-sta2-" + std::to_string(i)).c_str(), sta2, tid, true, 10));
        }
        MockOriginatorBlockAckAgreementHandler baHandler;
        baHandler.addAgreement(sta1, tid, true, blockAckWindow);
        baHandler.addAgreement(sta2, tid, true, blockAckWindow);
        auto result = runFirstTransmitStep(pendingQueue, mockHcf, {sta1, sta2}, &baHandler,
                16, maxPsduLength, maxPpduDuration, alignedDuration, txopPayloadBudget);
        requireCondition(result.inProgressLength == 2, "packing limit should admit exactly one HoL MPDU per STA");
        requireCondition(pendingQueue->getNumPackets() == 4, "MPDUs beyond the packing limit must remain queued");
        delete result.container;
    };

    runPackingLimitCase("ba-window", 1, 6500631, SimTime(5.484, SIMTIME_MS), SIMTIME_ZERO, SIMTIME_ZERO);
    runPackingLimitCase("psdu-length", 64, 50, SimTime(5.484, SIMTIME_MS), SIMTIME_ZERO, SIMTIME_ZERO);
    runPackingLimitCase("ppdu-duration", 64, 6500631, SimTime(500, SIMTIME_US), SIMTIME_ZERO, SIMTIME_ZERO);
    runPackingLimitCase("aligned-duration", 64, 6500631, SimTime(5.484, SIMTIME_MS), SimTime(500, SIMTIME_US), SIMTIME_ZERO);
    runPackingLimitCase("txop-duration", 64, 6500631, SimTime(5.484, SIMTIME_MS), SIMTIME_ZERO, SimTime(500, SIMTIME_US));
    EV << "Per-user A-MPDU packing enforced BA-window, PSDU, PPDU, aligned-duration, and TXOP limits.\n";
}

// Test 5: bounded AddbaReq retry bursts (3 attempts) and addbaFailureTimeout cooldown resumption.
{
    OriginatorBlockAckAgreementHandler retryHandler;
    MockOriginatorBlockAckAgreementPolicy retryPolicy;
    retryPolicy.addbaFailureTimeout = SimTime(1, SIMTIME_S);
    MockProcedureCallback retryCallback(&retryHandler);

    auto retryPacket = makeDataPacket("retry-sta1", sta1, tid, true);
    auto retryHeader = retryPacket->peekAtFront<Ieee80211DataHeader>();

    getSimulation()->setSimTime(SimTime::ZERO);
    retryHandler.processTransmittedDataFrame(retryPacket, retryHeader, &retryPolicy, &retryCallback);
    retryHandler.processTransmittedDataFrame(retryPacket, retryHeader, &retryPolicy, &retryCallback);
    retryHandler.processTransmittedDataFrame(retryPacket, retryHeader, &retryPolicy, &retryCallback);
    retryHandler.processTransmittedDataFrame(retryPacket, retryHeader, &retryPolicy, &retryCallback);

    auto agreement = retryHandler.getAgreement(sta1, tid);
    requireCondition(agreement != nullptr, "expected agreement after first AddbaReq");
    requireCondition(retryCallback.addbaReqCount == 3, "bounded AddbaReq burst should stop at 3 before cooldown");

    getSimulation()->setSimTime(SimTime(2, SIMTIME_S));
    retryHandler.processTransmittedDataFrame(retryPacket, retryHeader, &retryPolicy, &retryCallback);
    requireCondition(retryCallback.addbaReqCount == 4, "post-cooldown AddbaReq retry should resume without teardown");

    EV << "MAC-02 fallback reference: Hcf::startFrameSequence(ac) remains the SU path while AddbaReq retries are bounded by addbaFailureTimeout and processTransmittedDataFrame; AC_VO classification remains in Hcf management processing.\n";
    delete retryPacket;
}

clearPendingQueue(pendingQueue);

%contains: stdout
Active ADDBA agreements admitted two QoS packets.

%contains: stdout
Admitted packets moved to InProgressFrames with BLOCK_ACK and duration fields.

%contains: stdout
Inactive ADDBA agreement packet remained pending.

%contains: stdout
Missing agreement and wrong TID packets remained pending.

%contains: stdout
