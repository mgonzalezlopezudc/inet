%description:
Test standard equal-sized IEEE 802.11ax RU scheduling for fBW and fHoL.

%includes:
#include "inet/linklayer/ieee80211/mac/scheduler/HeDlSchedulerEqualSizedRUs.h"
#include "inet/linklayer/common/MacAddress.h"
#include "inet/common/Units.h"

%file: TestNetwork.ned
import inet.linklayer.ieee80211.mac.scheduler.HeDlSchedulerEqualSizedRUs;

network TestNetwork
{
    submodules:
        test: Test;
        schedulerFbw: HeDlSchedulerEqualSizedRUs {
            parameters:
                schedulingFunction = "fBW";
        }
        schedulerFhol: HeDlSchedulerEqualSizedRUs {
            parameters:
                schedulingFunction = "fHoL";
        }
        schedulerCap: HeDlSchedulerEqualSizedRUs {
            parameters:
                schedulingFunction = "fHoL";
                maxMuStations = 4;
        }
        schedulerFbwCap: HeDlSchedulerEqualSizedRUs {
            parameters:
                schedulingFunction = "fBW";
                maxMuStations = 2;
        }
        schedulerFholCap: HeDlSchedulerEqualSizedRUs {
            parameters:
                schedulingFunction = "fHoL";
                maxMuStations = 2;
        }
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;
using namespace inet::units::values;

static IIeee80211HeDlScheduler::ScheduleContext makeContext(int count, Hz bandwidth)
{
    IIeee80211HeDlScheduler::ScheduleContext context;
    context.channelCenterFrequency = Hz(5.18e9);
    context.channelBandwidth = bandwidth;
    for (int i = 0; i < count; ++i) {
        IIeee80211HeDlScheduler::CandidateInfo candidate;
        char address[32];
        snprintf(address, sizeof(address), "02:00:00:00:00:%02X", i + 1);
        candidate.staAddress = MacAddress(address);
        candidate.anchor = i == 0;
        candidate.holDelay = SimTime(count - i, SIMTIME_MS);
        candidate.holPacketBytes = 200;
        candidate.backlogBytes = 1000 - i;
        context.candidates.push_back(candidate);
    }
    if (!context.candidates.empty())
        context.anchorSta = context.candidates.front().staAddress;
    return context;
}

static void assertStandardLayout(
        const std::vector<IIeee80211HeDlScheduler::RuAllocation>& allocations,
        Hz bandwidth, int layoutCount)
{
    ASSERT(!allocations.empty());
    int expectedToneSize = getHeEqualRuToneSize(bandwidth, layoutCount);
    std::vector<Ieee80211HeRu> rus;
    for (const auto& allocation : allocations) {
        ASSERT(allocation.ru.toneSize == expectedToneSize);
        rus.push_back(allocation.ru);
    }
    ASSERT(validateHeRuLayout(rus, bandwidth));
}

%activity:
auto schedulerFbw = check_and_cast<HeDlSchedulerEqualSizedRUs *>(
        getParentModule()->getSubmodule("schedulerFbw"));
auto schedulerFhol = check_and_cast<HeDlSchedulerEqualSizedRUs *>(
        getParentModule()->getSubmodule("schedulerFhol"));
auto schedulerCap = check_and_cast<HeDlSchedulerEqualSizedRUs *>(
        getParentModule()->getSubmodule("schedulerCap"));
auto schedulerFbwCap = check_and_cast<HeDlSchedulerEqualSizedRUs *>(
        getParentModule()->getSubmodule("schedulerFbwCap"));
auto schedulerFholCap = check_and_cast<HeDlSchedulerEqualSizedRUs *>(
        getParentModule()->getSubmodule("schedulerFholCap"));

{
    const int fbwCounts[] = {1, 2, 2, 4, 4, 4, 4, 4, 9, 9};
    const int fholLayoutCounts[] = {1, 2, 4, 4, 9, 9, 9, 9, 9, 9};
    for (int users = 1; users <= 10; ++users) {
        auto context = makeContext(users, Hz(20e6));
        auto fbw = schedulerFbw->schedule(context);
        ASSERT((int)fbw.size() == std::min(users, fbwCounts[users - 1]));
        assertStandardLayout(fbw, context.channelBandwidth, fbwCounts[users - 1]);

        auto fhol = schedulerFhol->schedule(context);
        ASSERT((int)fhol.size() == std::min(users, 9));
        assertStandardLayout(fhol, context.channelBandwidth, fholLayoutCounts[users - 1]);
    }
    EV << "20 MHz fBW and fHoL tables matched the standard RU counts.\n";
}

{
    struct Case { double bandwidth; int users; int fbwCount; int fholCount; };
    const Case cases[] = {
        {40e6, 7, 4, 8},
        {80e6, 12, 8, 16},
        {160e6, 33, 32, 74}
    };
    for (const auto& testCase : cases) {
        auto context = makeContext(testCase.users, Hz(testCase.bandwidth));
        auto fbw = schedulerFbw->schedule(context);
        ASSERT((int)fbw.size() == testCase.fbwCount);
        assertStandardLayout(fbw, context.channelBandwidth, testCase.fbwCount);
        auto fhol = schedulerFhol->schedule(context);
        ASSERT((int)fhol.size() == testCase.users);
        assertStandardLayout(fhol, context.channelBandwidth, testCase.fholCount);
    }
    EV << "40, 80, and 160 MHz ceiling/floor layout selection passed.\n";
}

{
    auto context = makeContext(6, Hz(20e6));
    context.candidates[0].anchor = false;
    context.candidates[4].anchor = true;
    context.anchorSta = context.candidates[4].staAddress;
    auto anchorAddress = context.anchorSta;
    auto allocations = schedulerCap->schedule(context);
    ASSERT(allocations.size() == 4);
    ASSERT(allocations.front().staAddress == anchorAddress);
    assertStandardLayout(allocations, context.channelBandwidth, 4);
    EV << "Candidate cap preserved the mandatory anchor deterministically.\n";
}

{
    auto context = makeContext(3, Hz(20e6));
    context.candidates[0].holDelay = SimTime(1, SIMTIME_MS);
    context.candidates[0].backlogBytes = 100;
    context.candidates[1].holDelay = SimTime(2, SIMTIME_MS);
    context.candidates[1].backlogBytes = 5000;
    context.candidates[2].holDelay = SimTime(10, SIMTIME_MS);
    context.candidates[2].backlogBytes = 500;

    auto fbw = schedulerFbwCap->schedule(context);
    auto fhol = schedulerFholCap->schedule(context);
    ASSERT(fbw.size() == 2);
    ASSERT(fhol.size() == 2);
    ASSERT(fbw[0].staAddress == context.anchorSta);
    ASSERT(fhol[0].staAddress == context.anchorSta);
    ASSERT(fbw[1].staAddress == context.candidates[1].staAddress);
    ASSERT(fhol[1].staAddress == context.candidates[2].staAddress);

    auto expectedDuration = estimateHeMuUserDuration(B(context.candidates[1].backlogBytes),
            fbw[1].ru.toneSize, fbw[1].mcs, 1, false, context.guardInterval);
    ASSERT(fbw[1].estimatedDuration == expectedDuration);
    EV << "fBW prioritized backlog, fHoL prioritized delay, and packing duration used eligible backlog.\n";
}

{
    Ieee80211HeCapabilities local;
    Ieee80211HeCapabilities peer;
    peer.supportedChannelWidths = {Hz(20e6)};
    peer.rxMcsNss.maxMcsPerNss[0] = 3;
    peer.supportedRuToneSizes = {26};
    Ieee80211HeOperation operation;
    operation.operatingChannelWidth = Hz(20e6);
    std::vector<Ieee80211NegotiatedHeCapabilities> negotiated(2,
            negotiateHeCapabilities(local, peer, operation));
    ASSERT(negotiated[0].intersection.supportedChannelWidths.size() == 1);
    auto context = makeContext(2, Hz(20e6));
    for (int i = 0; i < 2; ++i)
        context.candidates[i].negotiatedHeCapabilities = &negotiated[i];
    auto allocations = schedulerFhol->schedule(context);
    ASSERT(allocations.size() == 2);
    for (const auto& allocation : allocations) {
        ASSERT(allocation.ru.toneSize == 26);
        ASSERT(allocation.mcs <= 3);
    }
    negotiated[1].intersection.dlOfdma = false;
    negotiated[1].valid = false;
    ASSERT(schedulerFhol->schedule(context).empty());
    EV << "Negotiated HE width, RU, DL-OFDMA, and MCS limits were enforced.\n";
}

EV << ".\n";

%contains: stdout
20 MHz fBW and fHoL tables matched the standard RU counts.
40, 80, and 160 MHz ceiling/floor layout selection passed.
Candidate cap preserved the mandatory anchor deterministically.
fBW prioritized backlog, fHoL prioritized delay, and packing duration used eligible backlog.
Negotiated HE width, RU, DL-OFDMA, and MCS limits were enforced.
.
