%description:
Test the real HeDlSchedulerEqualSizedRUs module. The implementation currently
uses equal-width RUs as a deliberate model simplification; this test guards that
behavior and does not claim full IEEE 802.11ax RU taxonomy coverage.

%includes:
#include "inet/linklayer/ieee80211/mac/scheduler/HeDlSchedulerEqualSizedRUs.h"
#include "inet/linklayer/common/MacAddress.h"
#include "inet/common/Units.h"
#include <set>

%file: TestNetwork.ned
import inet.linklayer.ieee80211.mac.scheduler.HeDlSchedulerEqualSizedRUs;

network TestNetwork
{
    submodules:
        test: Test;
        scheduler1: HeDlSchedulerEqualSizedRUs {
            parameters:
                maxMuStations = 1;
        }
        scheduler2: HeDlSchedulerEqualSizedRUs {
            parameters:
                maxMuStations = 2;
        }
        scheduler4: HeDlSchedulerEqualSizedRUs {
            parameters:
                maxMuStations = 4;
        }
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;
using namespace inet::units::values;

static void assertEqualRuCoverage(const std::vector<IIeee80211HeDlScheduler::RuAllocation>& allocs, Hz center, Hz bandwidth)
{
    if (allocs.empty())
        return;
    Hz ruBandwidth = bandwidth / (int)allocs.size();
    Hz covered = Hz(0);
    std::set<int> ruIndices;
    for (size_t i = 0; i < allocs.size(); i++) {
        const auto& ru = allocs[i].ru;
        ASSERT(ru.index == (int)i);
        ASSERT(ru.bandwidth == ruBandwidth);
        ASSERT(ru.centerFrequency == center - bandwidth / 2.0 + ruBandwidth * (i + 0.5));
        ASSERT(ruIndices.insert(ru.index).second);
        covered += ru.bandwidth;
    }
    ASSERT(covered == bandwidth);
}

static std::vector<MacAddress> makeCandidates()
{
    return {
        MacAddress("AA:BB:CC:DD:EE:01"),
        MacAddress("AA:BB:CC:DD:EE:02"),
        MacAddress("AA:BB:CC:DD:EE:03"),
        MacAddress("AA:BB:CC:DD:EE:04"),
        MacAddress("AA:BB:CC:DD:EE:05")
    };
}

%activity:
auto scheduler1 = check_and_cast<HeDlSchedulerEqualSizedRUs *>(getParentModule()->getSubmodule("scheduler1"));
auto scheduler2 = check_and_cast<HeDlSchedulerEqualSizedRUs *>(getParentModule()->getSubmodule("scheduler2"));
auto scheduler4 = check_and_cast<HeDlSchedulerEqualSizedRUs *>(getParentModule()->getSubmodule("scheduler4"));

Hz center(5.18e9);
Hz bandwidth(20e6);
auto candidates = makeCandidates();

{
    auto allocs = scheduler4->schedule({}, center, bandwidth);
    ASSERT(allocs.empty());
    EV << "Empty candidate list produced no RU allocations.\n";
}

{
    auto allocs = scheduler1->schedule(candidates, center, bandwidth);
    ASSERT(allocs.size() == 1);
    ASSERT(allocs[0].staAddress == candidates[0]);
    ASSERT(allocs[0].ru.bandwidth == bandwidth);
    ASSERT(allocs[0].ru.centerFrequency == center);
    EV << "maxMuStations=1 preserved first-seen station order.\n";
}

{
    auto allocs = scheduler2->schedule(candidates, center, bandwidth);
    ASSERT(allocs.size() == 2);
    ASSERT(allocs[0].staAddress == candidates[0]);
    ASSERT(allocs[1].staAddress == candidates[1]);
    assertEqualRuCoverage(allocs, center, bandwidth);
    EV << "maxMuStations=2 capped candidates and produced equal-width contiguous RUs.\n";
}

{
    auto allocs = scheduler4->schedule(candidates, center, bandwidth);
    ASSERT(allocs.size() == 4);
    for (int i = 0; i < 4; i++)
        ASSERT(allocs[i].staAddress == candidates[i]);
    for (const auto& alloc : allocs)
        ASSERT(alloc.staAddress != candidates[4]);
    assertEqualRuCoverage(allocs, center, bandwidth);
    EV << "maxMuStations=4 capped candidates, preserved order, and covered the channel exactly.\n";
}

EV << "Spec-gap guard: HeDlSchedulerEqualSizedRUs uses equal-width RUs only.\n";
EV << ".\n";

%contains: stdout
Empty candidate list produced no RU allocations.
maxMuStations=1 preserved first-seen station order.
maxMuStations=2 capped candidates and produced equal-width contiguous RUs.
maxMuStations=4 capped candidates, preserved order, and covered the channel exactly.
Spec-gap guard: HeDlSchedulerEqualSizedRUs uses equal-width RUs only.
.
