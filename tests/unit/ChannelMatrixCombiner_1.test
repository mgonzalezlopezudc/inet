%description:
This test checks single-stream MRC for SIMO and explicitly precoded MIMO channels.

%includes:
#include <cmath>
#include <limits>

#include "inet/common/math/Functions.h"
#include "inet/physicallayer/wireless/common/signal/ChannelMatrixCombiner.h"
#include "inet/physicallayer/wireless/common/signal/ChannelMatrixSignal.h"
#include "inet/physicallayer/wireless/common/signal/ChannelMatrixSnapshot.h"

%global:

using namespace inet;
using namespace inet::math;
using namespace inet::physicallayer;

class TimeVaryingTestChannelMatrixResponse : public IChannelMatrixResponse
{
  public:
    virtual bool isTimeInvariant() const override { return false; }
    virtual int getNumReceiveAntennas() const override { return 1; }
    virtual int getNumTransmitAntennas() const override { return 1; }
    virtual ChannelMatrix getChannelMatrix(simsec, Hz) const override {
        return ChannelMatrix(1, 1, {{1, 0}});
    }
};

template<typename Function>
static void expectRuntimeError(Function function, const char *message)
{
    try {
        function();
    }
    catch (const cRuntimeError&) {
        return;
    }
    throw cRuntimeError("Expected cRuntimeError: %s", message);
}

%activity:
ChannelMatrix simo(2, 1, {{3, 4}, {0, 12}});
ASSERT(ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(simo) == 169);

ChannelMatrix mimo(2, 2, {{1, 0}, {1, 0}, {1, 0}, {-1, 0}});
auto scale = 1 / std::sqrt(2.0);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(mimo,
        {{scale, 0}, {scale, 0}}) - 2) < 1e-14);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(mimo,
        {{1, 0}, {0, 0}}) - 2) < 1e-14);

auto effectiveChannel = ChannelMatrixCombiner::computeEffectiveChannel(mimo, {{1, 0}, {0, 0}});
ASSERT(effectiveChannel == std::vector<std::complex<double>>({{1, 0}, {1, 0}}));

ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 1, {}, {}, 1) - 2) < 1e-14);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 1, {{{1, 0}, {0, 0}}}, {9}, 1) - 1.1) < 1e-14);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 1, {{{1, 0}, {0, 1}}}, {3}, 1) - 8.0 / 7) < 1e-14);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 1, {{{1, 0}, {-1, 0}}}, {100}, 1) - 2) < 1e-12);
ASSERT(std::abs(ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {0, 1}}, 1, {{{1, 0}, {1, 0}}}, {3}, 2) - 0.625) < 1e-14);
auto firstInterfererOrder = ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 2, {{{1, 0}, {0, 1}}, {{2, 0}, {1, 0}}}, {3, 0.5}, 1);
auto secondInterfererOrder = ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
        {{1, 0}, {1, 0}}, 2, {{{2, 0}, {1, 0}}, {{1, 0}, {0, 1}}}, {0.5, 3}, 1);
ASSERT(std::abs(firstInterfererOrder - secondInterfererOrder) < 1e-14);

expectRuntimeError([&] { ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(mimo); }, "missing MIMO precoder");
expectRuntimeError([&] { ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(mimo, {{1, 0}}); }, "precoder size");
expectRuntimeError([&] { ChannelMatrixCombiner::computeSingleStreamMrcPowerGain(mimo, {{1, 0}, {1, 0}}); }, "precoder norm");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr({{1, 0}}, 1, {{{1, 0}}}, {}, 1);
}, "interferer count");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr({{1, 0}, {1, 0}}, 1, {{{1, 0}}}, {1}, 1);
}, "interferer dimension");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr({{1, 0}}, 1, {}, {}, 0);
}, "positive noise");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr({{1, 0}}, -1, {}, {}, 1);
}, "desired power");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr({{1, 0}}, 1, {{{1, 0}}}, {-1}, 1);
}, "interferer power");
expectRuntimeError([&] {
    ChannelMatrixCombiner::computeSingleStreamLmmseSinr(
            {{std::numeric_limits<double>::infinity(), 0}}, 1, {}, {}, 1);
}, "finite desired channel");

auto simoResponse = std::make_shared<const ConstantChannelMatrixResponse>(simo);
auto unitInputPower = makeShared<ConstantFunction<WpHz, Domain<simsec, Hz>>>(WpHz(1));
auto matrixSignal = std::make_shared<const ChannelMatrixSignal>(unitInputPower, simoResponse,
        std::vector<std::complex<double>>{{1, 0}});
ASSERT(matrixSignal->computeEffectiveChannel(simsec(0), GHz(5)) == simo.getCoefficients());
auto doubledInputPower = makeShared<ConstantFunction<WpHz, Domain<simsec, Hz>>>(WpHz(2));
auto doubledMatrixSignal = matrixSignal->withInputPower(doubledInputPower);
ASSERT(doubledMatrixSignal->getInputPower()->getValue(Point<simsec, Hz>(simsec(0), GHz(5))) == WpHz(2));
ASSERT(doubledMatrixSignal->getChannelMatrixResponse() == matrixSignal->getChannelMatrixResponse());
expectRuntimeError([&] {
    ChannelMatrixSignal(unitInputPower, simoResponse, {});
}, "matrix signal weight count");
expectRuntimeError([&] {
    ChannelMatrixSignal(unitInputPower, simoResponse, {{2, 0}});
}, "matrix signal weight norm");

auto desiredLmmseResponse = std::make_shared<const ConstantChannelMatrixResponse>(
        ChannelMatrix(2, 1, {{1, 0}, {1, 0}}));
auto interferingLmmseResponse = std::make_shared<const ConstantChannelMatrixResponse>(
        ChannelMatrix(2, 1, {{1, 0}, {0, 1}}));
auto desiredLmmseSignal = std::make_shared<const ChannelMatrixSignal>(unitInputPower,
        desiredLmmseResponse, std::vector<std::complex<double>>{{1, 0}});
auto lmmseStartTime = SimTime(1, SIMTIME_S);
auto lmmseEndTime = lmmseStartTime + SimTime(4, SIMTIME_US);
auto lmmseCenterFrequency = GHz(5);
auto lmmseBandwidth = MHz(1);
auto transientInterferencePower = makeShared<Boxcar2DFunction<WpHz, simsec, Hz>>(
        simsec(lmmseStartTime), simsec(lmmseStartTime + SimTime(2, SIMTIME_US)),
        lmmseCenterFrequency - lmmseBandwidth / 2, lmmseCenterFrequency + lmmseBandwidth / 2, WpHz(3));
auto interferingLmmseSignal = std::make_shared<const ChannelMatrixSignal>(transientInterferencePower,
        interferingLmmseResponse, std::vector<std::complex<double>>{{1, 0}});
auto lmmseSnir = ChannelMatrixCombiner::createStaticSingleStreamLmmseSnir(
        desiredLmmseSignal, {interferingLmmseSignal}, unitInputPower,
        lmmseStartTime, lmmseEndTime, lmmseCenterFrequency, lmmseBandwidth,
        SimTime(1, SIMTIME_US), kHz(500));
ASSERT(std::abs(lmmseSnir->getValue(Point<simsec, Hz>(
        simsec(lmmseStartTime + SimTime(500, SIMTIME_NS)), lmmseCenterFrequency)) - 8.0 / 7) < 1e-12);
ASSERT(std::abs(lmmseSnir->getValue(Point<simsec, Hz>(
        simsec(lmmseStartTime + SimTime(2500, SIMTIME_NS)), lmmseCenterFrequency)) - 2) < 1e-12);
auto lmmseInterval = Interval<simsec, Hz>(
        Point<simsec, Hz>(simsec(lmmseStartTime), lmmseCenterFrequency - lmmseBandwidth / 2),
        Point<simsec, Hz>(simsec(lmmseEndTime), lmmseCenterFrequency + lmmseBandwidth / 2),
        0b11, 0b00, 0b00);
ASSERT(std::abs(lmmseSnir->getMin(lmmseInterval) - 8.0 / 7) < 1e-12);
ASSERT(std::abs(lmmseSnir->getMax(lmmseInterval) - 2) < 1e-12);
ASSERT(std::abs(lmmseSnir->getMean(lmmseInterval) - 11.0 / 7) < 1e-12);
ASSERT(lmmseSnir->getValue(Point<simsec, Hz>(simsec(lmmseStartTime - SimTime(1, SIMTIME_US)),
        lmmseCenterFrequency)) == 0);
ASSERT(lmmseSnir->getValue(Point<simsec, Hz>(simsec(lmmseStartTime),
        lmmseCenterFrequency + lmmseBandwidth)) == 0);
expectRuntimeError([&] {
    ChannelMatrixCombiner::createStaticSingleStreamLmmseSnir(desiredLmmseSignal,
            {interferingLmmseSignal}, nullptr, lmmseStartTime, lmmseEndTime,
            lmmseCenterFrequency, lmmseBandwidth, SimTime(1, SIMTIME_US), kHz(500));
}, "L-MMSE background noise");
auto simoGain = ChannelMatrixCombiner::createStaticSingleStreamMrcPowerGain(simoResponse, 0,
        SimTime(1, SIMTIME_S), SimTime(2, SIMTIME_S), GHz(5), MHz(20), MHz(1));
ASSERT(std::abs(simoGain->getValue(Point<simsec, Hz>(simsec(1.5), GHz(5))) - 169) < 1e-14);
ASSERT(simoGain->getValue(Point<simsec, Hz>(simsec(0), GHz(5))) == 1);
ASSERT(simoGain->getValue(Point<simsec, Hz>(simsec(1.5), GHz(5) + MHz(20))) == 1);

ChannelMatrix selectedColumns(1, 2, {{2, 0}, {3, 0}});
auto selectedResponse = std::make_shared<const ConstantChannelMatrixResponse>(selectedColumns);
auto firstColumnGain = ChannelMatrixCombiner::createStaticSingleStreamMrcPowerGain(selectedResponse, 0,
        SimTime(1, SIMTIME_S), SimTime(2, SIMTIME_S), GHz(5), MHz(20), MHz(1));
auto secondColumnGain = ChannelMatrixCombiner::createStaticSingleStreamMrcPowerGain(selectedResponse, 1,
        SimTime(1, SIMTIME_S), SimTime(2, SIMTIME_S), GHz(5), MHz(20), MHz(1));
ASSERT(std::abs(firstColumnGain->getValue(Point<simsec, Hz>(simsec(1.5), GHz(5))) - 4) < 1e-14);
ASSERT(std::abs(secondColumnGain->getValue(Point<simsec, Hz>(simsec(1.5), GHz(5))) - 9) < 1e-14);
expectRuntimeError([&] {
    ChannelMatrixCombiner::createStaticSingleStreamMrcPowerGain(selectedResponse, 2,
            SimTime(1, SIMTIME_S), SimTime(2, SIMTIME_S), GHz(5), MHz(20), MHz(1));
}, "selected antenna range");
expectRuntimeError([&] {
    ChannelMatrixCombiner::createStaticSingleStreamMrcPowerGain(
            std::make_shared<const TimeVaryingTestChannelMatrixResponse>(), 0,
            SimTime(1, SIMTIME_S), SimTime(2, SIMTIME_S), GHz(5), MHz(20), MHz(1));
}, "time-varying matrix response");

std::cout << "Channel matrix combiner passed" << std::endl;

%contains: stdout
Channel matrix combiner passed
