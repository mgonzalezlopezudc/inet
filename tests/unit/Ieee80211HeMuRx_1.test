%description:
Test HE MU reception filtering at Ieee80211Receiver. Verifies that a station only
decodes its assigned RU from a single HE MU PPDU and that non-HE receivers get
only the legacy-visible duration indication.

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Receiver.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Transmission.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeMuUtil.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Tag_m.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211ModeSet.h"
#include "inet/physicallayer/wireless/common/analogmodel/scalar/ScalarReceptionAnalogModel.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/ISnir.h"
#include "inet/physicallayer/wireless/common/radio/packetlevel/Reception.h"
#include "inet/physicallayer/wireless/common/radio/packetlevel/ReceptionDecision.h"
#include "inet/physicallayer/wireless/common/contract/packetlevel/IReceptionResult.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/networklayer/common/NetworkInterface.h"
#include "inet/common/ProtocolTag_m.h"
#include "inet/common/Protocol.h"
#include "inet/common/packet/Packet.h"

%file: TestNetwork.ned

import inet.networklayer.common.InterfaceTable;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211RadioMedium;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211Receiver;
import inet.physicallayer.wireless.ieee80211.packetlevel.Ieee80211ScalarRadio;
import inet.mobility.static.StationaryMobility;

module DummyReceiverModule extends Ieee80211Receiver
{
    parameters:
        @class(DummyReceiverModule);
}

module MockNic
{
    parameters:
        @class(MockNicModule);
    submodules:
        radio: Ieee80211ScalarRadio {
            receiver.typename = "DummyReceiverModule";
        }
    connections allowunconnected:
        radio.upperLayerOut --> radio.upperLayerIn;
}

network TestNetwork
{
    parameters:
        @networkNode;
    submodules:
        test: Test;
        interfaceTable: InterfaceTable;
        radioMedium: Ieee80211RadioMedium;
        mobility: StationaryMobility;
}

%inifile: omnetpp.ini
[General]
network = TestNetwork
**.receiver.typename = "DummyReceiverModule"
**.nic*.interfaceTableModule = "^.interfaceTable"
**.mobilityModule = "^.^.^.mobility"
**.mobility.subjectModule = ""
**.constraintAreaMinX = 0m
**.constraintAreaMinY = 0m
**.constraintAreaMinZ = 0m
**.constraintAreaMaxX = 100m
**.constraintAreaMaxY = 100m
**.constraintAreaMaxZ = 0m
**.receiver.energyDetection = -100dBm
**.receiver.sensitivity = -90dBm
**.receiver.centerFrequency = 5.18GHz
**.receiver.bandwidth = 20MHz
**.receiver.modulation = "BPSK"
**.receiver.snirThreshold = 4dB
**.receiver.opMode = "ax"
**.receiver.bandName = "5 GHz"
**.receiver.channelNumber = 36

%global:

using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;

class MockIeee80211Transmission : public Ieee80211Transmission
{
  public:
    MockIeee80211Transmission(const IRadio *transmitter, const Packet *packet, const IIeee80211Mode *mode, const Ieee80211Channel *channel)
        : Ieee80211Transmission(
            transmitter,
            packet,
            0.0, 0.0, // startTime, endTime
            0.0, 0.0, 0.0, // preamble, header, data duration
            Coord(), Coord(), // start, end position
            Quaternion(), Quaternion(), // start, end orientation
            nullptr, nullptr, nullptr, nullptr, nullptr, // models
            mode, channel
        ) {}
};

class DummyReceiverModule : public Ieee80211Receiver {
  public:
    bool checkAssigned(const ITransmission *transmission) const {
        return isAssignedHeMuRu(transmission);
    }
    const IReceptionResult *computeTestReceptionResult(const IReception *reception, const ISnir *snir, const std::vector<const IReceptionDecision *> *decisions) const {
        return computeReceptionResult(nullptr, reception, nullptr, snir, decisions);
    }
};

class DummySnir : public ISnir {
  protected:
    const IReception *reception;

  public:
    DummySnir(const IReception *reception) : reception(reception) {}
    virtual const IReception *getReception() const override { return reception; }
    virtual const INoise *getNoise() const override { return nullptr; }
    virtual double getMin() const override { return 10; }
    virtual double getMax() const override { return 10; }
    virtual double getMean() const override { return 10; }
    virtual std::ostream& printToStream(std::ostream& stream, int level, int evFlags = 0) const override { return stream << "DummySnir"; }
};

class MockNicModule : public NetworkInterface {
  protected:
    virtual void initialize(int stage) override {
        // Minimal setup to prevent dynamic registrations
        if (stage == INITSTAGE_LOCAL) {
            state = UP;
            carrier = true;
        }
    }
    virtual int numInitStages() const override { return 1; }
};

Define_Module(DummyReceiverModule);
Define_Module(MockNicModule);

static Packet *makeHeMuPacket(const char *name, const std::vector<std::pair<Ieee80211HeRu, MacAddress>>& users)
{
    auto packet = new Packet(name);
    auto phyHeader = makeShared<Ieee80211HeMuPhyHeader>();
    for (const auto& entry : users) {
        Ieee80211HeMuUserInfo user;
        user.ruIndex = entry.first.index;
        user.ruToneSize = entry.first.toneSize;
        user.ruToneOffset = entry.first.toneOffset;
        user.staId = computeHeMuStaId(entry.second);
        phyHeader->appendUsers(user);
    }
    phyHeader->setChunkLength(b(16 + phyHeader->getUsersArraySize() * 73));
    packet->insertAtBack(phyHeader);
    auto containerHeader = makeShared<Ieee80211DataHeader>();
    containerHeader->setType(ST_DATA_WITH_QOS);
    containerHeader->setReceiverAddress(MacAddress::BROADCAST_ADDRESS);
    containerHeader->setChunkLength(b(288));
    packet->insertAtBack(containerHeader);
    for (const auto& entry : users) {
        auto payloadHeader = makeShared<Ieee80211HeMuRuPayloadHeader>();
        payloadHeader->setRuIndex(entry.first.index);
        payloadHeader->setRuToneSize(entry.first.toneSize);
        payloadHeader->setRuToneOffset(entry.first.toneOffset);
        payloadHeader->setStaId(computeHeMuStaId(entry.second));
        payloadHeader->setMpduLength(B(32));
        packet->insertAtBack(payloadHeader);
        packet->insertAtBack(makeShared<ByteCountChunk>(B(32)));
    }
    packet->insertAtBack(makeShared<Ieee80211MacTrailer>());
    packet->addTagIfAbsent<PacketProtocolTag>()->setProtocol(&Protocol::ieee80211HePhy);
    return packet;
}

%activity:

// Get dynamic module type for MockNic
cModuleType *nicType = cModuleType::find("MockNic");
if (!nicType) {
    throw cRuntimeError("Could not find MockNic module type");
}

// Instantiate two NIC modules to act as two different stations
cModule *nic1 = nicType->create("nic1", getSystemModule());
nic1->buildInside();
auto netIface1 = check_and_cast<MockNicModule *>(nic1);
netIface1->setMacAddress(MacAddress("00:11:22:33:44:55"));
nic1->callInitialize();

cModule *nic2 = nicType->create("nic2", getSystemModule());
nic2->buildInside();
auto netIface2 = check_and_cast<MockNicModule *>(nic2);
netIface2->setMacAddress(MacAddress("66:77:88:99:AA:BB"));
nic2->callInitialize();

// Retrieve the receiver submodules from both NICs and cast them to our DummyReceiverModule
auto rxModule1 = check_and_cast<DummyReceiverModule *>(nic1->getSubmodule("radio")->getSubmodule("receiver"));
auto rxModule2 = check_and_cast<DummyReceiverModule *>(nic2->getSubmodule("radio")->getSubmodule("receiver"));

auto radio1 = check_and_cast<IRadio *>(nic1->getSubmodule("radio"));

// Retrieve mode and channel for mock transmissions
auto modeSet = Ieee80211ModeSet::getModeSet("ax");
auto mode = const_cast<Ieee80211ModeSet *>(modeSet)->getMode(0);
auto channel = new Ieee80211Channel(nullptr, 1);

auto rus = calculateHeRus(Hz(5.18e9), Hz(20e6), 4);

// --- Test 1: Single PPDU with STA1 on RU 0 ---
{
    auto packet = makeHeMuPacket("he-mu-ppdu", {{rus[0], MacAddress("00:11:22:33:44:55")}, {rus[1], MacAddress("66:77:88:99:AA:BB")}});

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);

    bool possible1 = rxModule1->checkAssigned(trans);
    EV << "STA1 assigned in HE MU PPDU: " << (possible1 ? "PASS" : "FAIL") << "\n";

    bool possible2 = rxModule2->checkAssigned(trans);
    EV << "STA2 assigned in HE MU PPDU: " << (possible2 ? "PASS" : "FAIL") << "\n";

    delete trans;
    delete packet;
}

// --- Test 2: Single PPDU without STA1 allocation ---
{
    auto packet = makeHeMuPacket("he-mu-ppdu-no-sta1", {{rus[1], MacAddress("66:77:88:99:AA:BB")}});

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);

    bool possible1 = rxModule1->checkAssigned(trans);
    EV << "STA1 unassigned in HE MU PPDU: " << (!possible1 ? "PASS" : "FAIL") << "\n";

    bool possible2 = rxModule2->checkAssigned(trans);
    EV << "STA2 assigned after STA1 omitted: " << (possible2 ? "PASS" : "FAIL") << "\n";

    delete trans;
    delete packet;
}

// --- Test 3: Single PPDU assigned to neither STA ---
{
    auto packet = makeHeMuPacket("he-mu-ppdu-other-sta", {{rus[2], MacAddress("02:00:00:00:00:03")}});

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);

    // Both should be FALSE
    bool possible1 = rxModule1->checkAssigned(trans);
    bool possible2 = rxModule2->checkAssigned(trans);
    EV << "STA1 absent from HE MU PPDU: " << (!possible1 ? "PASS" : "FAIL") << "\n";
    EV << "STA2 absent from HE MU PPDU: " << (!possible2 ? "PASS" : "FAIL") << "\n";

    delete trans;
    delete packet;
}

// --- Test 4: HE MU PHY packet with an empty allocation map is rejected ---
{
    auto packet = makeHeMuPacket("empty-allocation-packet", {});

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);

    bool possible1 = rxModule1->checkAssigned(trans);
    bool possible2 = rxModule2->checkAssigned(trans);
    EV << "STA1 empty HE MU allocation map: " << (!possible1 ? "PASS" : "FAIL") << "\n";
    EV << "STA2 empty HE MU allocation map: " << (!possible2 ? "PASS" : "FAIL") << "\n";

    delete trans;
    delete packet;
}

// --- Test 5: Non-HE PHY packets are not filtered by HE RU assignment ---
{
    auto packet = new Packet("legacy-packet");
    packet->insertAtBack(makeShared<ByteCountChunk>(B(32)));

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);

    bool possible1 = rxModule1->checkAssigned(trans);
    bool possible2 = rxModule2->checkAssigned(trans);
    EV << "STA1 legacy packet without HE MU PHY tag: " << (possible1 ? "PASS" : "FAIL") << "\n";
    EV << "STA2 legacy packet without HE MU PHY tag: " << (possible2 ? "PASS" : "FAIL") << "\n";

    delete trans;
    delete packet;
}

// --- Test 6: Non-HE receiver gets HE MU legacy duration indication, not RU payload ---
{
    rxModule1->setModeSet(Ieee80211ModeSet::getModeSet("g(erp)"));

    auto packet = makeHeMuPacket("he-mu-ppdu-for-legacy", {{rus[0], MacAddress("00:11:22:33:44:55")}});

    auto trans = new MockIeee80211Transmission(radio1, packet, mode, channel);
    auto analogModel = new ScalarReceptionAnalogModel(
            SimTime(100, SIMTIME_US),
            SimTime(100, SIMTIME_US),
            SimTime(800, SIMTIME_US),
            Hz(5.18e9),
            Hz(20e6),
            mW(1));
    auto reception = new Reception(
            radio1,
            trans,
            SIMTIME_ZERO,
            SimTime(1, SIMTIME_MS),
            Coord(), Coord(),
            Quaternion(), Quaternion(),
            analogModel);
    auto decision = new ReceptionDecision(reception, IRadioSignal::SIGNAL_PART_WHOLE, true, true, true);
    auto decisions = new std::vector<const IReceptionDecision *> { decision };
    DummySnir snir(reception);

    auto result = rxModule1->computeTestReceptionResult(reception, &snir, decisions);
    auto receivedPacket = result->getPacket();
    bool hasLegacyIndication = receivedPacket->hasTag<Ieee80211HeMuLegacyPreambleInd>();
    bool hasMacProtocol = receivedPacket->getTag<PacketProtocolTag>()->getProtocol() == &Protocol::ieee80211HePhy;
    EV << "Legacy receiver gets HE MU duration indication: " << (hasLegacyIndication ? "PASS" : "FAIL") << "\n";
    EV << "Legacy receiver does not get MAC RU payload: " << (hasMacProtocol ? "PASS" : "FAIL") << "\n";

    delete result;
    delete decision;
    delete reception;
    delete trans;
    delete packet;

    rxModule1->setModeSet(Ieee80211ModeSet::getModeSet("ax"));
}

// Cleanup Channel
delete channel;

EV << ".\n";

%contains: stdout
STA1 assigned in HE MU PPDU: PASS
STA2 assigned in HE MU PPDU: PASS
STA1 unassigned in HE MU PPDU: PASS
STA2 assigned after STA1 omitted: PASS
STA1 absent from HE MU PPDU: PASS
STA2 absent from HE MU PPDU: PASS
STA1 empty HE MU allocation map: PASS
STA2 empty HE MU allocation map: PASS
STA1 legacy packet without HE MU PHY tag: PASS
STA2 legacy packet without HE MU PHY tag: PASS
Legacy receiver gets HE MU duration indication: PASS
Legacy receiver does not get MAC RU payload: PASS
.
