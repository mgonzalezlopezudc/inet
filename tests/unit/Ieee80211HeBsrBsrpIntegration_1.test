%description:
Test HE BSR/BSRP coordinator integration for fresh, stale, implicit reports, trigger selection, and scheduler allocations.

%includes:
#include "inet/linklayer/ieee80211/mac/coordinationfunction/HeUlCoordinator.h"
#include "inet/linklayer/ieee80211/mac/coordinationfunction/HeUlDefaultTriggerPolicy.h"
#include "inet/linklayer/ieee80211/mac/scheduler/IIeee80211HeUlScheduler.h"
#include "inet/linklayer/ieee80211/mib/Ieee80211Mib.h"

%file: TestNetwork.ned
import inet.linklayer.ieee80211.mac.coordinationfunction.HeUlCoordinator;
import inet.linklayer.ieee80211.mac.coordinationfunction.HeUlDefaultTriggerPolicy;
import inet.linklayer.ieee80211.mib.Ieee80211Mib;

simple RecordingHeUlScheduler
{
    parameters:
        @class(RecordingHeUlScheduler);
}

network TestNetwork
{
    submodules:
        test: Test;
        mib: Ieee80211Mib;
        ulScheduler: RecordingHeUlScheduler;
        ulTriggerPolicy: HeUlDefaultTriggerPolicy {
            parameters:
                minimumTriggerInterval = 0s;
        }
        coordinator: HeUlCoordinator {
            parameters:
                enabled = true;
                reportMaxAge = 10ms;
                ocwMin = 0;
                ocwMax = 7;
        }
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:
using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;
using namespace inet::units::values;

class RecordingHeUlScheduler : public cSimpleModule, public IIeee80211HeUlScheduler
{
  public:
    ScheduleContext lastContext;
    int calls = 0;

    virtual Schedule schedule(const ScheduleContext& context) override
    {
        calls++;
        lastContext = context;
        Schedule schedule;
        int index = 0;
        for (const auto& candidate : context.candidates) {
            RuAllocation allocation;
            allocation.staAddress = candidate.staAddress;
            allocation.associationId = candidate.associationId;
            allocation.accessCategory = candidate.selectedAccessCategory;
            allocation.tid = candidate.selectedTid;
            allocation.ru.index = index++;
            allocation.ru.toneSize = 26;
            allocation.ru.dataSubcarriers = getHeRuDataSubcarrierCount(26);
            allocation.ru.pilotSubcarriers = getHeRuPilotSubcarrierCount(26);
            allocation.ru.bandwidth = Hz(26 * 78125.0);
            allocation.mcs = 2;
            allocation.estimatedDuration = SimTime(500, SIMTIME_US);
            schedule.allocations.push_back(allocation);
        }
        if (!schedule.allocations.empty())
            schedule.commonDuration = SimTime(1, SIMTIME_MS);
        return schedule;
    }
};

Define_Module(RecordingHeUlScheduler);

static void associate(Ieee80211Mib *mib, const MacAddress& sta)
{
    mib->bssAccessPointData.stations[sta] = Ieee80211Mib::ASSOCIATED;
    mib->allocateAssociationId(sta);
}

%activity:
auto mib = check_and_cast<Ieee80211Mib *>(getParentModule()->getSubmodule("mib"));
auto coordinator = check_and_cast<HeUlCoordinator *>(getParentModule()->getSubmodule("coordinator"));
auto scheduler = check_and_cast<RecordingHeUlScheduler *>(getParentModule()->getSubmodule("ulScheduler"));

MacAddress sta1("02:00:00:00:10:01");
MacAddress sta2("02:00:00:00:10:02");
MacAddress sta3("02:00:00:00:10:03");
associate(mib, sta1);
associate(mib, sta2);
associate(mib, sta3);
auto aid1 = mib->getAssociationId(sta1);
auto aid2 = mib->getAssociationId(sta2);
auto aid3 = mib->getAssociationId(sta3);

ASSERT(coordinator->selectTrigger(mib) == IIeee80211HeUlTriggerPolicy::BSRP_TRIGGER);
EV << "Missing fresh reports selected a BSRP Trigger.\n";

coordinator->updateBufferStatus(aid1, AC_BE, 0, 1200, false);
coordinator->updateBufferStatus(aid2, AC_VI, 5, 0, true);
ASSERT(coordinator->selectTrigger(mib) == IIeee80211HeUlTriggerPolicy::BASIC_TRIGGER);
ASSERT(coordinator->getPreferredAccessCategory() == AC_VI);
EV << "Fresh backlogged and retry reports selected a Basic Trigger.\n";

auto freshSchedule = coordinator->createSchedule(mib, Hz(5.18e9), Hz(20e6),
        SimTime(2, SIMTIME_MS), -85, 10, 0, 0, 0);
ASSERT(freshSchedule.allocations.size() == 2);
ASSERT(scheduler->lastContext.candidates.size() == 2);
ASSERT(scheduler->lastContext.candidates[0].hasFreshReport);
ASSERT(scheduler->lastContext.candidates[0].associationId == aid1);
ASSERT(scheduler->lastContext.candidates[0].getSelectedBacklogBytes() == 1200);
ASSERT(scheduler->lastContext.candidates[1].associationId == aid2);
ASSERT(scheduler->lastContext.candidates[1].retryPending);
ASSERT(coordinator->getBufferStatus().at(aid1).scheduledBytes[AC_BE] == 1200);
EV << "Fresh reports reached the UL scheduler and produced allocations.\n";

wait(0.011);
ASSERT(coordinator->selectTrigger(mib) == IIeee80211HeUlTriggerPolicy::BSRP_TRIGGER);
auto staleSchedule = coordinator->createSchedule(mib, Hz(5.18e9), Hz(20e6),
        SimTime(2, SIMTIME_MS), -85, 10, 0, 0, 0);
ASSERT(staleSchedule.allocations.empty());
ASSERT(scheduler->lastContext.candidates.empty());
EV << "Stale reports were excluded and selected BSRP polling.\n";

coordinator->updateBufferStatus(aid3, AC_VO, 6, 800, false);
ASSERT(coordinator->selectTrigger(mib) == IIeee80211HeUlTriggerPolicy::BASIC_TRIGGER);
auto implicitSchedule = coordinator->createSchedule(mib, Hz(5.18e9), Hz(20e6),
        SimTime(2, SIMTIME_MS), -85, 10, 0, 0, 0);
ASSERT(implicitSchedule.allocations.size() == 1);
ASSERT(scheduler->lastContext.candidates.size() == 1);
ASSERT(scheduler->lastContext.candidates[0].associationId == aid3);
ASSERT(scheduler->lastContext.candidates[0].selectedAccessCategory == AC_VO);
ASSERT(scheduler->lastContext.candidates[0].selectedTid == 6);
ASSERT(coordinator->getBufferStatus().at(aid3).scheduledBytes[AC_VO] == 800);
EV << "Implicit BSR refresh drove Basic Trigger scheduling for the reporting STA.\n";

EV << ".\n";

%contains: stdout
Missing fresh reports selected a BSRP Trigger.

%contains: stdout
Fresh backlogged and retry reports selected a Basic Trigger.

%contains: stdout
Fresh reports reached the UL scheduler and produced allocations.

%contains: stdout
Stale reports were excluded and selected BSRP polling.

%contains: stdout
Implicit BSR refresh drove Basic Trigger scheduling for the reporting STA.

%contains: stdout
.
