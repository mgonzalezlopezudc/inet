%description:
Test that PcapRecorder dynamically sizes the Radiotap present bitmap and populates the Rate, MCS, A-MPDU, VHT, HE, and 0-length-PSDU fields.

%includes:
#include <vector>
#include "inet/common/packet/chunk/ByteCountChunk.h"
#include "inet/common/packet/chunk/BytesChunk.h"
#include "inet/common/packet/recorder/PcapRecorder.h"
#include "inet/linklayer/ieee80211/mac/Ieee80211Frame_m.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HePhyCalculator.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211Tag_m.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211EhtMode.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211HeMode.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211HtMode.h"
#include "inet/physicallayer/wireless/ieee80211/mode/Ieee80211VhtMode.h"

%file: TestNetwork.ned

import inet.common.packet.recorder.PcapRecorder;

simple TestablePcapRecorder extends PcapRecorder
{
    parameters:
        @class(TestablePcapRecorder);
}

network TestNetwork
{
    submodules:
        test: Test;
        recorder: TestablePcapRecorder {
            pcapFile = "";
            verbose = false;
        }
}

%inifile: omnetpp.ini
[General]
network = TestNetwork

%global:

using namespace inet;
using namespace inet::ieee80211;
using namespace inet::physicallayer;

class RecordingPcapWriter : public IPcapWriter
{
  public:
    std::vector<std::vector<uint8_t>> records;

    virtual void open(const char *, unsigned int, int) override { }
    virtual void close() override { }
    virtual bool isOpen() const override { return true; }
    virtual void setFlush(bool) override { }

    virtual void writePacket(simtime_t, const Packet *packet, b frontOffset, b backOffset,
            Direction, NetworkInterface *, PcapLinkType linkType) override
    {
        ASSERT(linkType == LINKTYPE_IEEE802_11_RADIOTAP);
        auto length = packet->getDataLength() - frontOffset - backOffset;
        records.push_back(packet->peekDataAt<BytesChunk>(frontOffset, length)->getBytes());
    }
};

class TestablePcapRecorder : public PcapRecorder
{
  public:
    void setWriter(IPcapWriter *writer)
    {
        delete pcapWriter;
        pcapWriter = writer;
    }

    void writeIeee80211(const Packet *packet, b frontOffset = b(0), b backOffset = b(0))
    {
        writePacket(&Protocol::ieee80211Mac, packet, frontOffset, backOffset, DIRECTION_UNDEFINED, nullptr);
    }
};

class MockEhtMode : public Ieee80211EhtMode
{
  public:
    MockEhtMode() : Ieee80211EhtMode("mock-eht", nullptr, nullptr, BAND_6GHZ) {}
};

static void appendMpdu(Packet& aggregate, const std::vector<uint8_t>& bytes, bool appendPadding)
{
    auto delimiter = makeShared<Ieee80211MpduSubframeHeader>();
    delimiter->setLength(bytes.size());
    aggregate.insertAtBack(delimiter);
    aggregate.insertAtBack(makeShared<BytesChunk>(bytes));
    auto paddingLength = (4 - (4 + bytes.size()) % 4) % 4;
    if (appendPadding && paddingLength != 0)
        aggregate.insertAtBack(makeShared<ByteCountChunk>(B(paddingLength)));
}

static uint16_t readUint16(const std::vector<uint8_t>& bytes, size_t offset)
{
    return bytes.at(offset) | bytes.at(offset + 1) << 8;
}

Define_Module(TestablePcapRecorder);

%activity:

auto recorder = check_and_cast<TestablePcapRecorder *>(getModuleByPath("recorder"));
auto writer = new RecordingPcapWriter();
recorder->setWriter(writer);

auto printRecord = [this](int idx, const std::vector<uint8_t>& rec) {
    std::string hexDump = "";
    for (auto b : rec) {
        char buf[10];
        sprintf(buf, "%02X ", b);
        hexDump += buf;
    }
    EV << "Test " << idx << " Size: " << rec.size() << ", Bytes: " << hexDump << "\n";
};

// Test 1: EHT Packet
{
    Packet packet("eht-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto modeReq = packet.addTag<Ieee80211ModeReq>();
    MockEhtMode mockEhtMode;
    modeReq->setMode(&mockEhtMode);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(1, record);

    ASSERT(record.size() >= 20);
    ASSERT(record[0] == 0); // version
    ASSERT(record[1] == 0); // pad
    ASSERT(record[2] == 20 && record[3] == 0); // length (20)
    ASSERT(record[4] == 0x02 && record[5] == 0 && record[6] == 0 && record[7] == 0x80); // Word 0 (flags + extension bit)
    ASSERT(record[8] == 0x08 && record[9] == 0 && record[10] == 0 && record[11] == 0); // Word 1 (EHT bit)
    ASSERT(record[12] == 0x10); // flags (RADIOTAP_F_FCS)
    ASSERT(record[13] == 0 && record[14] == 0 && record[15] == 0); // padding to 4-byte boundary
    ASSERT(record[16] == 0 && record[17] == 0 && record[18] == 0 && record[19] == 0); // EHT known u32 (0)
}

// Test 2: HT Packet
{
    writer->records.clear();
    Packet packet("ht-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto modeReq = packet.addTag<Ieee80211ModeReq>();
    auto htMode = Ieee80211HtCompliantModes::getCompliantMode(&Ieee80211HtmcsTable::htMcs0BW20MHz, Ieee80211HtMode::BAND_5GHZ, Ieee80211HtPreambleMode::HT_PREAMBLE_MIXED, Ieee80211HtModeBase::HT_GUARD_INTERVAL_LONG);
    modeReq->setMode(htMode);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(2, record);
    ASSERT(record.size() == 13 + 4);
    ASSERT(record[0] == 0);
    ASSERT(record[2] == 13 && record[3] == 0);
    ASSERT(record[4] == 0x06 && record[5] == 0 && record[6] == 0x08 && record[7] == 0);
    ASSERT(record[8] == 0x10);
    ASSERT(record[9] == 13); // 6.5 Mbps / 0.5 = 13
    ASSERT(record[10] == 0x17);
    ASSERT(record[11] == 0x00);
    ASSERT(record[12] == 0);
}

// Test 3: VHT Packet
{
    writer->records.clear();
    Packet packet("vht-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto modeReq = packet.addTag<Ieee80211ModeReq>();
    auto vhtMode = Ieee80211VhtCompliantModes::getCompliantMode(&Ieee80211VhtmcsTable::vhtMcs0BW20MHzNss1, Ieee80211VhtMode::BAND_5GHZ, Ieee80211VhtPreambleMode::HT_PREAMBLE_MIXED, Ieee80211VhtModeBase::HT_GUARD_INTERVAL_LONG);
    modeReq->setMode(vhtMode);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(3, record);
    ASSERT(record.size() == 22 + 4);
    ASSERT(record[0] == 0);
    ASSERT(record[2] == 22 && record[3] == 0);
    ASSERT(record[4] == 0x06 && record[5] == 0 && record[6] == 0x20 && record[7] == 0);
    ASSERT(record[8] == 0x10);
    ASSERT(record[9] == 13); // 6.5 Mbps / 0.5 = 13
    ASSERT(record[10] == 0x45 && record[11] == 0);
    ASSERT(record[12] == 0);
    ASSERT(record[13] == 0);
    ASSERT(record[14] == 1);
    ASSERT(record[18] == 0);
}

// Test 4: A-MPDU Packet
{
    writer->records.clear();
    const std::vector<uint8_t> firstMpdu = {0x08, 0x01, 0x02, 0x03, 0x04};
    const std::vector<uint8_t> secondMpdu = {0x88, 0x11, 0x12, 0x13, 0x14, 0x15, 0x16};

    Packet aggregate("ampdu");
    aggregate.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{0xAA, 0xBB}));
    appendMpdu(aggregate, firstMpdu, true);
    appendMpdu(aggregate, secondMpdu, false);
    aggregate.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{0xCC, 0xDD, 0xEE}));

    recorder->writeIeee80211(&aggregate, B(2), B(3));

    ASSERT(writer->records.size() == 2);
    for (size_t i = 0; i < writer->records.size(); i++) {
        const auto& record = writer->records[i];
        printRecord(4 + i, record);
        const auto& expectedMpdu = (i == 0 ? firstMpdu : secondMpdu);
        ASSERT(record.size() == 20 + expectedMpdu.size());
        ASSERT(record[2] == 20 && record[3] == 0);
        ASSERT(record[4] == 0x02 && record[5] == 0 && record[6] == 0x10 && record[7] == 0);
        ASSERT(record[8] == 0x10);
        if (i == 0) {
            ASSERT(record[16] == 0x04 && record[17] == 0);
        } else {
            ASSERT(record[16] == 0x0C && record[17] == 0);
        }
    }
}

// Test 5: 0-length-PSDU Packet
{
    writer->records.clear();
    Packet packet("ndp-packet");

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(6, record);
    ASSERT(record.size() == 10);
    ASSERT(record[2] == 10 && record[3] == 0);
    ASSERT(record[4] == 0x02 && record[5] == 0 && record[6] == 0 && record[7] == 0x04);
    ASSERT(record[8] == 0x10);
    ASSERT(record[9] == 0);
}

// Test 6: HE SU Packet. The six HE words start at byte 10 after Flags and Rate.
{
    writer->records.clear();
    Packet packet("he-su-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto modeReq = packet.addTag<Ieee80211ModeReq>();
    auto heMode = Ieee80211HeCompliantModes::getCompliantMode(
            &Ieee80211HemcsTable::heMcs2BW40MHzNss2, Ieee80211HeMode::BAND_5GHZ,
            Ieee80211HePreambleMode::HE_PREAMBLE_SU,
            Ieee80211HeModeBase::HE_GUARD_INTERVAL_MEDIUM, true);
    modeReq->setMode(heMode);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(7, record);
    ASSERT(record[2] == 18 && record[3] == 0);
    ASSERT(record[4] == 0x06 && record[5] == 0 && record[6] == 0x80 && record[7] == 0);
    ASSERT(readUint16(record, 10) == 0x40A0); // SU; MCS, coding, and bandwidth known
    ASSERT(readUint16(record, 12) == 0x0002); // GI known
    ASSERT(readUint16(record, 14) == 0x2200); // MCS 2, LDPC
    ASSERT(readUint16(record, 16) == 0x0000);
    ASSERT(readUint16(record, 18) == 0x0011); // 40 MHz, 1.6 us GI
    ASSERT(readUint16(record, 20) == 0x0002); // two space-time streams
}

// Test 7: HE ER SU Packet. PPDU format is a value, not a "known" bit.
{
    writer->records.clear();
    Packet packet("he-er-su-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto modeReq = packet.addTag<Ieee80211ModeReq>();
    auto heMode = Ieee80211HeCompliantModes::getCompliantMode(
            &Ieee80211HemcsTable::heMcs0BW20MHzNss1, Ieee80211HeMode::BAND_5GHZ,
            Ieee80211HePreambleMode::HE_PREAMBLE_ER_SU,
            Ieee80211HeModeBase::HE_GUARD_INTERVAL_LONG);
    modeReq->setMode(heMode);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(8, record);
    ASSERT(record[2] == 18 && record[3] == 0);
    ASSERT(readUint16(record, 10) == 0x40A1); // HE_EXT_SU
    ASSERT(readUint16(record, 12) == 0x0002);
    ASSERT(readUint16(record, 14) == 0x0000); // MCS 0, BCC
    ASSERT(readUint16(record, 18) == 0x0027); // 242-tone RU, 3.2 us GI
    ASSERT(readUint16(record, 20) == 0x0001);
}

// Test 8: HE DL MU Packet. The regular HE field describes the captured user;
// no HE-MU field is emitted because the request does not contain HE-SIG-B RU
// allocation codes.
{
    writer->records.clear();
    Packet packet("he-dl-mu-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto request = packet.addTag<Ieee80211HeMuReq>();
    request->setPpduFormat(HE_MU_DOWNLINK);
    request->setRuToneSize(106);
    request->setStaId(37);
    request->setMcs(5);
    request->setNumberOfSpatialStreams(2);
    request->setDcm(true);
    request->setGuardInterval(HE_GI_0_8_US);
    request->setCoding(HE_CODING_LDPC);
    request->setSpatialReuse(3);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(9, record);
    ASSERT(record[2] == 22 && record[3] == 0);
    ASSERT(record[4] == 0x02 && record[5] == 0 && record[6] == 0x80 && record[7] == 0);
    ASSERT(readUint16(record, 10) == 0x4CF2); // HE_MU and captured-user fields known
    ASSERT(readUint16(record, 12) == 0x0002);
    ASSERT(readUint16(record, 14) == 0x3500); // DL, MCS 5, DCM, LDPC
    ASSERT(readUint16(record, 16) == 0x0253); // STA-ID 37, spatial reuse 3
    ASSERT(readUint16(record, 18) == 0x0006); // 106-tone RU, 0.8 us GI
    ASSERT(readUint16(record, 20) == 0x0002);
}

// Test 9: HE trigger-based uplink Packet.
{
    writer->records.clear();
    Packet packet("he-tb-packet");
    packet.insertAtBack(makeShared<BytesChunk>(std::vector<uint8_t>{1, 2, 3, 4}));
    auto request = packet.addTag<Ieee80211HeMuReq>();
    request->setPpduFormat(HE_TRIGGER_BASED_UPLINK);
    request->setRuToneSize(52);
    request->setMcs(1);
    request->setNumberOfSpatialStreams(1);
    request->setGuardInterval(HE_GI_1_6_US);
    request->setCoding(HE_CODING_BCC);
    request->setSpatialReuse(7);

    recorder->writeIeee80211(&packet);

    ASSERT(writer->records.size() == 1);
    const auto& record = writer->records[0];
    printRecord(10, record);
    ASSERT(record[2] == 22 && record[3] == 0);
    ASSERT(readUint16(record, 10) == 0x44F3); // HE_TRIG; no MU STA-ID bit
    ASSERT(readUint16(record, 12) == 0x0002);
    ASSERT(readUint16(record, 14) == 0x0180); // UL, MCS 1, BCC
    ASSERT(readUint16(record, 16) == 0x0007);
    ASSERT(readUint16(record, 18) == 0x0015); // 52-tone RU, 1.6 us GI
    ASSERT(readUint16(record, 20) == 0x0001);
}

EV << "Radiotap extended fields and present bitmaps tested successfully.\n";

%contains: stdout
Radiotap extended fields and present bitmaps tested successfully.
