%description:
Test IEEE 802.11 HE Resource Unit (RU) calculation and HE-MU PHY user info

%includes:
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeRu.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211HeMuUtil.h"
#include "inet/physicallayer/wireless/ieee80211/packetlevel/Ieee80211PhyHeader_m.h"

%global:

using namespace inet;
using namespace inet::physicallayer;

%activity:
Hz centerFrequency(5.18e9);
Hz bandwidth(20e6);

// Test RU partitioning: 4 RUs on a 20MHz channel
std::vector<Ieee80211HeRu> rus = calculateHeRus(centerFrequency, bandwidth, 4);
EV << "Number of RUs: " << rus.size() << "\n";
for (const auto& ru : rus) {
    EV << "RU " << ru.index << ": center=" << ru.centerFrequency.get()
       << " Hz, bandwidth=" << ru.bandwidth.get() << " Hz\n";
}

auto phyHeader = makeShared<Ieee80211HeMuPhyHeader>();
auto appendUser = [&] (const Ieee80211HeRu& ru, const MacAddress& staAddress) {
    Ieee80211HeMuUserInfo user;
    user.ruIndex = ru.index;
    user.ruToneSize = ru.toneSize;
    user.ruToneOffset = ru.toneOffset;
    user.staId = computeHeMuStaId(staAddress);
    phyHeader->appendUsers(user);
};
appendUser(rus[0], MacAddress("00:11:22:33:44:55"));
appendUser(rus[2], MacAddress("66:77:88:99:AA:BB"));

EV << "Users in HE-MU PHY header: " << phyHeader->getUsersArraySize() << "\n";
EV << "User 0: RU " << phyHeader->getUsers(0).ruIndex << ", STA-ID=" << phyHeader->getUsers(0).staId << "\n";
EV << "User 1: RU " << phyHeader->getUsers(1).ruIndex << ", STA-ID=" << phyHeader->getUsers(1).staId << "\n";

// Mixed layout: the two 106-tone branches and the central 26-tone RU.
std::vector<Ieee80211HeRu> mixed;
if (!allocateHeRus(centerFrequency, bandwidth, {106, 106, 26}, mixed))
    throw cRuntimeError("Could not allocate the standard 106+106+26 mixed layout");
if (mixed.size() != 3 || mixed[0].toneOffset != 0 ||
        mixed[1].toneOffset != 136 || mixed[2].toneOffset != 108)
    throw cRuntimeError("Unexpected positions in the standard 106+106+26 mixed layout");
if (!validateHeRuLayout(mixed, bandwidth))
    throw cRuntimeError("The standard mixed layout failed validation");

// Non-overlapping is insufficient: positions must be allocation-tree nodes.
auto invalid = mixed;
invalid[2].toneOffset++;
if (validateHeRuLayout(invalid, bandwidth))
    throw cRuntimeError("A non-catalog RU position passed validation");
bool noncanonicalPilotOffsetRejected = false;
try {
    getHeRuPilotToneIndices(242, 52, 1);
}
catch (const std::invalid_argument&) {
    noncanonicalPilotOffsetRejected = true;
}
if (!noncanonicalPilotOffsetRejected)
    throw cRuntimeError("A noncanonical pilot-tone offset was not rejected as invalid input");

auto catalog80 = getHeRuAllocationCatalog(centerFrequency, Hz(80e6));
int central26Count = 0;
for (const auto& ru : catalog80)
    if (ru.toneSize == 26 && ru.toneOffset == 485)
        central26Count++;
if (central26Count != 1)
    throw cRuntimeError("The 80 MHz allocation tree does not contain exactly one central 26-tone RU");

constexpr double toneSpacing = 78125;
for (auto channelBandwidth : {MHz(20), MHz(40), MHz(80), MHz(160)}) {
    auto channelTones = getHeChannelToneCount(channelBandwidth);
    for (const auto& ru : getHeRuAllocationCatalog(centerFrequency, channelBandwidth)) {
        auto lowerFrequency = ru.centerFrequency - ru.bandwidth / 2;
        auto upperFrequency = ru.centerFrequency + ru.bandwidth / 2;
        auto checkToneContainment = [&] (int tone) {
            auto toneCenter = centerFrequency + Hz(tone * toneSpacing);
            if (toneCenter < lowerFrequency || toneCenter > upperFrequency)
                throw cRuntimeError("Physical HE RU tone %d lies outside its modeled passband", tone);
        };
        for (auto tone : getHeRuDataToneIndices(channelTones, ru.toneSize, ru.toneOffset))
            checkToneContainment(tone);
        for (auto tone : getHeRuPilotToneIndices(channelTones, ru.toneSize, ru.toneOffset))
            checkToneContainment(tone);
    }
}

EV << "Mixed allocation used the standard central 26-tone RU.\n";
EV << "Non-catalog RU placement was rejected.\n";
EV << ".\n";

%contains: stdout
Number of RUs: 4
RU 2: center=5.17254e+09 Hz, bandwidth=4.0625e+06 Hz
RU 5: center=5.17668e+09 Hz, bandwidth=4.0625e+06 Hz
RU 10: center=5.18332e+09 Hz, bandwidth=4.0625e+06 Hz
RU 13: center=5.18746e+09 Hz, bandwidth=4.0625e+06 Hz
Users in HE-MU PHY header: 2
User 0: RU 2, STA-ID=1109
User 1: RU 10, STA-ID=699
Mixed allocation used the standard central 26-tone RU.
Non-catalog RU placement was rejected.
.
