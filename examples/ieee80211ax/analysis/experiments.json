      "measurement": {"start": 0.3, "end": 2.0},
      "output": "examples/ieee80211ax/analysis/figures/fragmentation/fragmentation-and-ack-overhead.png",
      "conditions": [
        {"label": "Dynamic", "config": "DynamicFragmentation"},
        {"label": "Static", "config": "StaticFragmentation"},
        {"label": "Unfragmented", "config": "NoFragmentation"}
      ]
    },
    "uora": {
      "ini": "examples/ieee80211ax/ul_ofdma/omnetpp.ini",
