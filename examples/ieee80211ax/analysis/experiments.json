{
  "schema_version": 1,
  "default_repetitions": 5,
  "evidence_contracts": {
    "fragmentation": [
      {"kind": "normative", "requirement": "Peer capability gates dynamic fragmentation", "results": ["fragment capability state"]},
      {"kind": "normative", "requirement": "Fragment numbers, More Fragments, sizes, and ACK/BA state are consistent", "results": ["fragment number", "fragment size", "More Fragments", "acknowledgmentFrameType"]}
    ],
    "uora": [
      {"kind": "normative", "requirement": "Random-access attempts use advertised RA-RUs", "results": ["heUlRandomAccessAttempt", "heUlRandomAccessSuccess", "heRuToneOffset", "heStaId"]}
    ],
    "twt": [
      {"kind": "normative", "requirement": "Announced TWT requester signals wake presence before responder traffic", "results": ["PS-Poll/APSD trigger sequence"]},
      {"kind": "metric", "requirement": "Energy comparison preserves delivery", "results": ["powerConsumption", "packetReceived"]}
    ],
    "rate": [
      {"kind": "model", "requirement": "Rate decisions are joined to outcomes and retries", "results": ["heRateSelectedMcs", "heRateSelectedNss", "heRateSuccessProbability", "heRateTxSuccess", "heRateRetryCount"]}
    ],
    "er": [
      {"kind": "normative", "requirement": "The treatment selects a legal HE-ER-SU PPDU while the control remains HE-SU", "results": ["radiotap HE format", "HE MCS", "RU size"]},
      {"kind": "metric", "requirement": "Cell-boundary delivery is measured over matched seeds without assuming a standards-mandated gain", "results": ["packetReceived", "packetDropIncorrectlyReceived"]}
    ],
    "puncturing": [
      {"kind": "normative", "requirement": "RU allocations never overlap punctured subchannels", "results": ["hePuncturedSubchannelMask", "heRuToneOffset", "heRuToneSize", "heStaId"]},
      {"kind": "metric", "requirement": "Interference comparison uses delivered application bytes", "results": ["packetReceived"]}
    ],
    "mimo": [
      {"kind": "normative", "requirement": "A PPDU serves multiple users with disjoint spatial streams", "results": ["heStaId", "heSpatialStreams", "heStreamStartIndex"]}
    ],
    "bss": [
      {"kind": "normative", "requirement": "OBSS classification, OBSS/PD threshold, CCA, and power-limit decisions are observable", "results": ["OBSS classification", "OBSS/PD threshold", "reuse decision", "transmit power limit"]},
      {"kind": "metric", "requirement": "Reuse comparison reports delivery, fairness, and concurrent airtime", "results": ["packetReceived", "transmissionState"]}
    ],
    "width": [
      {"kind": "normative", "requirement": "TXVECTOR channel width matches the configured 20/40/80/160 MHz mode", "results": ["configured channel width", "HE bandwidth metadata"]},
      {"kind": "metric", "requirement": "Capacity comparison uses goodput and delay", "results": ["packetReceived", "endToEndDelay"]}
    ],
    "dl": [
      {"kind": "model", "requirement": "Per-user scheduling is keyed by STA ID without MAC-address filtering", "results": ["heStaId", "heScheduledPsduBytes", "heUserPpduDuration"]},
      {"kind": "metric", "requirement": "Per-user delivery and delay come from application results", "results": ["packetReceived", "endToEndDelay"]}
    ],
    "bsr": [
      {"kind": "normative", "requirement": "Reported backlog is joined to scheduler-consumed backlog", "results": ["heUlBufferStatusReportedBytes", "heUlBufferStatusScheduledBytes"]}
    ]
  },
  "groups": {
    "fragmentation": {
      "ini": "examples/ieee80211ax/mac_features/dynamic_fragmentation/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/mac_features/dynamic_fragmentation/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 2.0},
      "output": "examples/ieee80211ax/analysis/figures/fragmentation/fragmentation-and-ack-overhead.png",
      "conditions": [
        {"label": "Dynamic", "config": "DynamicFragmentation"},
        {"label": "Static", "config": "StaticFragmentation"},
        {"label": "Unfragmented", "config": "NoFragmentation"}
      ]
    },
    "uora": {
      "ini": "examples/ieee80211ax/ul_ofdma/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/ul_ofdma/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 2.0},
      "output": "examples/ieee80211ax/analysis/figures/uora/uora-dashboard.png",
      "conditions": [
        {"label": "Light, 1 RA-RU", "config": "UoraLightContention"},
        {"label": "Heavy, 1 RA-RU", "config": "UoraHeavyContention"},
        {"label": "Heavy, 5 RA-RUs", "config": "UoraMoreRandomAccessRus"}
      ]
    },
    "twt": {
      "ini": "examples/ieee80211ax/twt/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/twt/results",
      "expected_repetitions": 5,
      "measurement": {"start": 10.0, "end": 100.0},
      "output": "examples/ieee80211ax/analysis/figures/twt/twt-state-and-energy.png",
      "conditions": [
        {"label": "Baseline", "config": "BaselineEnergy", "metadata": {"sink_module_regex": "\\.server\\.app\\["}},
        {"label": "TWT", "config": "TwtEnergySaving", "metadata": {"minimum_delivery_ratio": 0.95, "sink_module_regex": "\\.server\\.app\\["}}
      ]
    },
    "rate": {
      "ini": "examples/ieee80211ax/he_rate_adaptation/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/he_rate_adaptation/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.5, "end": 1.7},
      "output": "examples/ieee80211ax/analysis/figures/rate/rate-adaptation-timeline.png",
      "conditions": [
        {"label": "Mobile HE Minstrel", "config": "HeMinstrelMobile"}
      ]
    },
    "er": {
      "ini": "examples/ieee80211ax/he_er_su/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/he_er_su/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 2.0},
      "output": "examples/ieee80211ax/analysis/figures/er/he-er-su-boundary.png",
      "conditions": [
        {"label": "HE-SU", "config": "CellBoundaryHeSu"},
        {"label": "HE-ER-SU", "config": "CellBoundaryHeErSu"}
      ]
    },
    "puncturing": {
      "ini": "examples/ieee80211ax/he_features/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/he_features/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 0.95},
      "output": "examples/ieee80211ax/analysis/figures/puncturing/puncturing-frequency-allocation.png",
      "conditions": [
        {"label": "Clean", "config": "CleanChannelBaseline"},
        {"label": "Interference, unpunctured", "config": "LegacyInterferenceWithoutPuncturing"},
        {"label": "Interference, punctured", "config": "PreamblePuncturingUnderInterference"},
        {"label": "Runtime puncturing", "config": "DynamicPuncturing"}
      ]
    },
    "mimo": {
      "ini": "examples/ieee80211ax/multi_user/mu_mimo/downlink.ini",
      "result_dir": "examples/ieee80211ax/multi_user/mu_mimo/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.55, "end": 0.88},
      "output": "examples/ieee80211ax/analysis/figures/mimo/mu-mimo-spatial-stream-matrix.png",
      "conditions": [
        {"label": "20 MHz OFDMA", "config": "EqualSizedRUs_fBW", "result_dir": "examples/ieee80211ax/dl_ofdma/results"},
        {"label": "20 MHz MU-MIMO", "config": "DlMuMimo"}
      ]
    },
    "bss": {
      "ini": "examples/ieee80211ax/bss_coloring/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/bss_coloring/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 0.95},
      "output": "examples/ieee80211ax/analysis/figures/bss/bss-coloring-comparison.png",
      "conditions": [
        {"label": "Disabled", "config": "BssColoringDisabled", "metadata": {"spatial_reuse_evidence": "disabled"}},
        {"label": "Conservative", "config": "ObssPdConservative", "metadata": {"spatial_reuse_evidence": "enabled", "obss_pd_dbm": -81}},
        {"label": "Enabled", "config": "BssColoringEnabled", "metadata": {"spatial_reuse_evidence": "enabled", "obss_pd_dbm": -79}},
        {"label": "Aggressive", "config": "ObssPdAggressive", "metadata": {"spatial_reuse_evidence": "enabled", "obss_pd_dbm": -78}},
        {"label": "Color collision", "config": "BssColoringCollision", "metadata": {"spatial_reuse_evidence": "collision"}}
      ]
    },
    "width": {
      "ini": "examples/ieee80211ax/he_channel_widths/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/he_channel_widths/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 0.43},
      "output": "examples/ieee80211ax/analysis/figures/width/channel-width-dashboard.png",
      "conditions": [
        {"label": "20 MHz", "config": "Width20MHz", "metadata": {"bandwidth_mhz": 20}},
        {"label": "40 MHz", "config": "Width40MHz", "metadata": {"bandwidth_mhz": 40}},
        {"label": "80 MHz", "config": "Width80MHz", "metadata": {"bandwidth_mhz": 80}},
        {"label": "160 MHz", "config": "Width160MHz", "metadata": {"bandwidth_mhz": 160}}
      ]
    },
    "dl": {
      "ini": "examples/ieee80211ax/dl_ofdma/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/dl_ofdma/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 0.88},
      "output": "examples/ieee80211ax/analysis/figures/dl/dl-scheduler-dashboard.png",
      "conditions": [
        {"label": "EDCA", "config": "SuEdcaBaseline", "metadata": {"workload": "symmetric"}},
        {"label": "fBW", "config": "EqualSizedRUs_fBW", "metadata": {"workload": "symmetric"}},
        {"label": "fHoL", "config": "EqualSizedRUs_fHoL", "metadata": {"workload": "symmetric"}},
        {"label": "Backlog", "config": "BacklogBased", "metadata": {"workload": "asymmetric", "offered_bps_by_index": [80000000, 8000000, 800000]}},
        {"label": "HoL min delay", "config": "HoLMinDelay", "metadata": {"workload": "asymmetric", "offered_bps_by_index": [80000000, 8000000, 800000]}}
      ]
    },
    "bsr": {
      "ini": "examples/ieee80211ax/he_bsr/omnetpp.ini",
      "result_dir": "examples/ieee80211ax/he_bsr/results",
      "expected_repetitions": 5,
      "measurement": {"start": 0.3, "end": 1.9},
      "output": "examples/ieee80211ax/analysis/figures/bsr/bsr-reported-vs-scheduled.png",
      "conditions": [
        {"label": "Fresh BSR", "config": "BurstyTraffic"},
        {"label": "Stale BSR", "config": "StaleBsr"}
      ]
    }
  }
}
