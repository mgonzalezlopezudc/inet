        {"label": "fBW", "config": "EqualSizedRUs_fBW", "metadata": {"workload": "symmetric"}},
        {"label": "fHoL", "config": "EqualSizedRUs_fHoL", "metadata": {"workload": "symmetric"}},
        {"label": "Backlog", "config": "BacklogBased", "metadata": {"workload": "asymmetric", "offered_bps_by_index": [80000000, 8000000, 800000]}},
